@model Convocation.Entities.UserPermission
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Delete User Permission";
}
<div class="form-card">
    <h3 class="form-title mb-4 text-danger">Delete User Permission</h3>
    <p>Are you sure you want to delete this mapping?</p>
    <dl class="row">
        <dt class="col-sm-3">User</dt>
        <dd class="col-sm-9">@Model.UserAccount?.FullName</dd>
        <dt class="col-sm-3">Permission</dt>
        <dd class="col-sm-9">@Model.Permission?.PermissionName</dd>
    </dl>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="UserPermissionId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>