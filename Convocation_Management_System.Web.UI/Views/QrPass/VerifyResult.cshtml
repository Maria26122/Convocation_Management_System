@model Convocation.Entities.QrPass

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "QR Verification Result";
}

<div class="form-card">
    <h3 class="form-title mb-4">QR Verification Result</h3>

    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label fw-bold">QR Code Text</label>
            <div class="form-control">@Model.QrCodeText</div>
        </div>

        <div class="col-md-6">
            <label class="form-label fw-bold">Status</label>
            <div class="form-control">
                @(Model.IsUsed ? "Already Used" : "Valid")
            </div>
        </div>

        <div class="col-md-6">
            <label class="form-label fw-bold">Participant</label>
            <div class="form-control">
                @Model.Registration?.Participant?.StudentId
            </div>
        </div>

        <div class="col-md-6">
            <label class="form-label fw-bold">Department</label>
            <div class="form-control">
                @Model.Registration?.Participant?.Department
            </div>
        </div>

        <div class="col-md-6">
            <label class="form-label fw-bold">Event</label>
            <div class="form-control">
                @Model.Registration?.Event?.EventTitle
            </div>
        </div>

        <div class="col-md-6">
            <label class="form-label fw-bold">Guest Count</label>
            <div class="form-control">
                @Model.Registration?.GuestCount
            </div>
        </div>
    </div>

    <div class="mt-4">
        @if (!Model.IsUsed)
        {
            <form asp-action="ConfirmEntry" method="post">
                <input type="hidden" name="qrPassId" value="@Model.QrPassId" />
                <button type="submit" class="btn btn-success">Confirm Entry</button>
                <a asp-action="Verify" class="btn btn-secondary">Back</a>
            </form>
        }
        else
        {
            <div class="alert alert-warning mt-3">
                This QR pass has already been used.
            </div>
            <a asp-action="Verify" class="btn btn-secondary">Back</a>
        }
    </div>
</div>