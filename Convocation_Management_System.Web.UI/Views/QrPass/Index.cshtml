<table class="table table-bordered table-striped align-middle">
    <thead class="table-light">
        <tr>
            <th>Registration</th>
            <th>Participant</th>
            <th>Event</th>
            <th>QR Code</th>
            <th>QR Image</th>
            <th>Status</th>
            <th>Generated Date</th>
            <th width="160">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>#@item.RegistrationId</td>

                <td>
                    @item.Registration?.Participant?.StudentId
                </td>

                <td>
                    @item.Registration?.Event?.EventTitle
                </td>

                <td>
                    <small>@item.QrCodeText</small>
                </td>

                <td>
                    @if (!string.IsNullOrEmpty(item.QrImagePath))
                    {
                        <img src="@item.QrImagePath"
                             width="70"
                             height="70"
                             class="img-thumbnail" />
                    }
                    else
                    {
                        <span class="text-muted">No Image</span>
                    }
                </td>

                <td>
                    @if (item.IsUsed)
                    {
                        <span class="badge bg-success">Used</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Unused</span>
                    }
                </td>

                <td>
                    @item.IssuedAt.ToString("dd MMM yyyy hh:mm tt")
                </td>

                <td>
                    <a asp-action="Details" asp-route-id="@item.QrPassId" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.QrPassId" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.QrPassId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>