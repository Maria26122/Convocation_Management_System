@{
    ViewData["Title"] = "QR Scan";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h3>QR Scanner (Gate Entry System)</h3>

<div class="card p-3">

    <label>Scan QR Code</label>

    <input type="text" id="qrInput" class="form-control"
           placeholder="Scan or paste QR code here" />

    <br />

    <button class="btn btn-success" onclick="scanQr()">
        Submit Scan
    </button>

    <hr />

    <div id="result"></div>

</div>

<script>
    async function scanQr() {
        const qr = document.getElementById("qrInput").value;

        const response = await fetch('/QrPass/ScanQr', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'qrCode=' + encodeURIComponent(qr)
        });

        const data = await response.json();

        if (data.success) {
            document.getElementById("result").innerHTML =
                `<div class="alert alert-success">
                    ${data.message} <br/>
                    Name: ${data.name} <br/>
                    Student ID: ${data.studentId}
                </div>`;
        }
        else {
            document.getElementById("result").innerHTML =
                `<div class="alert alert-danger">
                    ${data.message}
                </div>`;
        }
    }
</script>