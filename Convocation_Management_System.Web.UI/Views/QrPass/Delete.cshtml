@model Convocation.Entities.QrPass

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Delete QR Pass";
}

<div class="delete-card">
    <h3 class="delete-title mb-2 text-danger">Delete QR Pass</h3>
    <p class="text-soft">Are you sure you want to delete this QR pass?</p>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="label-title">Registration ID</div>
            <div class="value-text">#@Model.RegistrationId</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">QR Code</div>
            <div class="value-text">@Model.QrCodeText</div>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-4">
        <input type="hidden" asp-for="QrPassId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>