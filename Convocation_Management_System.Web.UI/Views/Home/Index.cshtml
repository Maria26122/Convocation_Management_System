@model IEnumerable<Convocation.Entities.Event>

@{
    ViewData["Title"] = "Convocation Management System";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Convocation Management System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
            body {
                margin: 0;
                background: #f6f8fc;
                font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
                color: #1f2937;
            }

            .topbar {
                background: #ffffff;
                border-bottom: 1px solid #e5e7eb;
                padding: 16px 0;
            }

            .brand {
                font-size: 24px;
                font-weight: 800;
                color: #5b5bd6;
                margin: 0;
            }

            .hero-section {
                padding: 70px 0 50px;
            }

            .hero-card {
                background: linear-gradient(135deg, #eef2ff, #ffffff);
                border-radius: 28px;
                padding: 50px 40px;
                box-shadow: 0 12px 28px rgba(15, 23, 42, 0.06);
                text-align: center;
            }

            .hero-title {
                font-size: 42px;
                font-weight: 800;
                color: #1f2d3d;
                margin-bottom: 16px;
            }

            .hero-text {
                font-size: 16px;
                color: #6b7280;
                max-width: 820px;
                margin: 0 auto 28px;
                line-height: 1.8;
            }

            .hero-btn {
                min-width: 150px;
                border-radius: 12px;
                padding: 11px 20px;
                font-weight: 700;
            }

            .section-wrap {
                padding: 10px 0 70px;
            }

            .section-title {
                font-size: 30px;
                font-weight: 800;
                text-align: center;
                margin-bottom: 10px;
                color: #1f2d3d;
            }

            .section-subtitle {
                text-align: center;
                color: #6b7280;
                margin-bottom: 35px;
            }

            .event-card {
                background: #ffffff;
                border: 1px solid #e5e7eb;
                border-radius: 22px;
                padding: 24px;
                height: 100%;
                box-shadow: 0 10px 25px rgba(15, 23, 42, 0.05);
                transition: 0.2s ease;
            }

                .event-card:hover {
                    transform: translateY(-4px);
                }

            .event-icon {
                width: 54px;
                height: 54px;
                border-radius: 16px;
                background: #eef2ff;
                color: #5b5bd6;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 22px;
                margin-bottom: 16px;
            }

            .event-title {
                font-size: 22px;
                font-weight: 800;
                color: #1f2d3d;
                margin-bottom: 14px;
            }

            .event-line {
                color: #4b5563;
                margin-bottom: 10px;
                font-size: 15px;
            }

                .event-line i {
                    width: 20px;
                    color: #6366f1;
                }

            .event-actions {
                margin-top: 18px;
                display: flex;
                gap: 10px;
                flex-wrap: wrap;
            }

                .event-actions .btn {
                    border-radius: 12px;
                    font-weight: 700;
                }

            .empty-box {
                background: #ffffff;
                border: 1px dashed #d1d5db;
                border-radius: 22px;
                padding: 36px;
                text-align: center;
                color: #6b7280;
            }

            .footer {
                background: #ffffff;
                border-top: 1px solid #e5e7eb;
                padding: 18px 0;
                text-align: center;
                color: #6b7280;
                font-size: 14px;
            }

            @@media (max-width: 768px) {
                .hero-card {
                    padding: 35px 20px;
                }

                .hero-title {
                    font-size: 32px;
                }
            }
    </style>
</head>
<body>

    <div class="topbar">
        <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h2 class="brand">Convocation CMS</h2>

            <div class="d-flex gap-2">
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary hero-btn">Login</a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-primary hero-btn">Create Account</a>
            </div>
        </div>
    </div>

    <section class="hero-section">
        <div class="container">
            <div class="hero-card">
                <h1 class="hero-title">Convocation Management System</h1>
                <p class="hero-text">
                    View upcoming convocation events, create your account, complete registration,
                    pay your fee, and get your QR pass for event-day entry — all in one place.
                </p>

                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary hero-btn">Get Started</a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary hero-btn">Login</a>
                </div>
            </div>
        </div>
    </section>

    <section class="section-wrap">
        <div class="container">
            <h2 class="section-title">Upcoming Convocation Events</h2>
            <p class="section-subtitle">Choose an event and continue with your registration process.</p>

            @{
                var today = DateTime.Today;
            }

            @if (Model != null && Model.Any())
            {
                <div class="row g-4">
                    @foreach (var item in Model)
                    {
                        var isUpcoming = item.EventDate.Date >= today;
                        var isClosed = item.EventDate.Date < today;

                        <div class="col-md-6 col-lg-4">
                            <div class="event-card">
                                <div class="event-icon">
                                    <i class="fas fa-graduation-cap"></i>
                                </div>

                                <div class="event-title">@item.EventTitle</div>

                                <div class="event-line">
                                    <i class="fas fa-calendar-days"></i>
                                    @item.EventDate.ToString("dd MMM yyyy")
                                </div>

                                <div class="event-line">
                                    <i class="fas fa-location-dot"></i>
                                    @(string.IsNullOrWhiteSpace(item.Venue) ? "TBA" : item.Venue)
                                </div>

                                <div class="event-line">
                                    <i class="fas fa-user-group"></i>
                                    Max Guests: @item.MaxGuestAllowed
                                </div>

                                <div class="event-line">
                                    <i class="fas fa-money-bill-wave"></i>
                                    Base Fee: ৳@item.BaseFee
                                </div>

                                <div class="mt-3">
                                    @if (isUpcoming)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill">
                                            Registration Open
                                        </span>
                                    }
                                    else if (isClosed)
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2 rounded-pill">
                                            Registration Closed
                                        </span>
                                    }
                                </div>

                                <div class="event-actions">
                                    @if (isUpcoming)
                                    {
                                        <a asp-controller="Registration"
                                               asp-action="Create"
                                               asp-route-eventId="@item.EventId"
                                               class="btn btn-primary flex-fill">
                                            Register Event
                                        </a>

                                        <a asp-controller="Account"
                                               asp-action="Register"
                                               asp-route-eventId="@item.EventId"
                                               class="btn btn-outline-primary flex-fill">
                                            Create Account
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-secondary flex-fill" disabled>
                                            Registration Closed
                                        </button>

                                        <a asp-controller="Account"
                                               asp-action="Login"
                                               class="btn btn-outline-secondary flex-fill">
                                            Login
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-box">
                    <h5 class="mb-2">No events available</h5>
                    <p class="mb-0">Please add active events from the admin panel.</p>
                </div>
            }
        </div>
    </section>

    <div class="footer">
        <div class="container">
            © 2026 Convocation Management System
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>