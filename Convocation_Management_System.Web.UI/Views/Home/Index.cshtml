@model IEnumerable<Convocation.Entities.Event>

@{
    ViewData["Title"] = "Convocation Management System";
    Layout = null;
    var now = DateTime.Now;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Convocation Management System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
            body {
                margin: 0;
                background: #f6f8fc;
                font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
                color: #1f2937;
            }

            .navbar-custom {
                background: rgba(255, 255, 255, 0.96);
                backdrop-filter: blur(10px);
                border-bottom: 1px solid #e5e7eb;
                padding: 14px 0;
                box-shadow: 0 6px 18px rgba(15, 23, 42, 0.06);
                z-index: 1030;
            }

            .brand-wrap {
                display: flex;
                align-items: center;
                padding: 0;
                margin-right: 18px;
            }

            .brand-logo-round {
                width: 96px;
                height: 96px;
                border-radius: 50%;
                object-fit: cover;
                background: #ffffff;
                border: 3px solid #eef2f7;
                padding: 6px;
                box-shadow: 0 8px 20px rgba(15, 23, 42, 0.12);
                transition: transform 0.2s ease, box-shadow 0.2s ease;
            }

                .brand-logo-round:hover {
                    transform: scale(1.04);
                    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.16);
                }

            .custom-toggler {
                border: 1px solid #dbe2ea;
                border-radius: 12px;
                padding: 8px 10px;
                box-shadow: none;
            }

                .custom-toggler:focus {
                    box-shadow: none;
                    border-color: #c7d2fe;
                }

            .navbar-nav {
                gap: 6px;
            }

            .nav-link-custom {
                display: flex;
                align-items: center;
                gap: 8px;
                color: #475569 !important;
                font-weight: 600;
                font-size: 15px;
                padding: 10px 14px !important;
                border-radius: 12px;
                transition: all 0.2s ease;
            }

                .nav-link-custom:hover {
                    color: #4338ca !important;
                    background: #eef2ff;
                }

            .nav-icon {
                color: #6366f1;
                font-size: 14px;
                width: 16px;
                text-align: center;
            }

            .nav-action-wrap {
                margin-left: 18px;
            }

            .nav-btn {
                border-radius: 12px;
                padding: 10px 18px;
                font-weight: 700;
                font-size: 14px;
                box-shadow: none;
            }

            .nav-btn-outline {
                border-width: 1.5px;
            }

            .nav-btn-fill {
                box-shadow: 0 8px 18px rgba(79, 70, 229, 0.18);
            }

            .banner-section {
                padding: 28px 0 10px;
            }

            .banner-card {
                background: linear-gradient(135deg, #eef2ff 0%, #ffffff 60%, #f5f3ff 100%);
                border-radius: 30px;
                overflow: hidden;
                box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
            }

            .banner-content {
                padding: 60px 50px;
            }

            .mini-badge {
                display: inline-block;
                padding: 8px 14px;
                background: rgba(79, 70, 229, 0.10);
                color: #4f46e5;
                border-radius: 999px;
                font-weight: 700;
                font-size: 13px;
                margin-bottom: 18px;
            }

            .banner-title {
                font-size: 44px;
                font-weight: 800;
                color: #111827;
                line-height: 1.2;
                margin-bottom: 16px;
            }

            .banner-text {
                font-size: 16px;
                line-height: 1.8;
                color: #6b7280;
                margin-bottom: 28px;
                max-width: 650px;
            }

            .banner-buttons .btn {
                min-width: 160px;
                border-radius: 14px;
                padding: 12px 20px;
                font-weight: 700;
            }

            .banner-side {
                background: linear-gradient(180deg, #4f46e5, #7c3aed);
                height: 100%;
                min-height: 320px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                text-align: center;
                padding: 30px;
            }

            .banner-side-box i {
                font-size: 54px;
                margin-bottom: 18px;
            }

            .banner-side-box h3 {
                font-weight: 800;
                margin-bottom: 10px;
            }

            .section-wrap {
                padding: 60px 0 70px;
            }

            .section-title {
                font-size: 32px;
                font-weight: 800;
                text-align: center;
                color: #111827;
                margin-bottom: 10px;
            }

            .section-subtitle {
                text-align: center;
                color: #6b7280;
                margin-bottom: 36px;
            }

            .event-card {
                background: #ffffff;
                border: 1px solid #e5e7eb;
                border-radius: 22px;
                padding: 24px;
                height: 100%;
                box-shadow: 0 12px 28px rgba(15, 23, 42, 0.05);
                transition: 0.25s ease;
            }

                .event-card:hover {
                    transform: translateY(-4px);
                }

            .event-icon {
                width: 56px;
                height: 56px;
                border-radius: 16px;
                background: #eef2ff;
                color: #4f46e5;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 24px;
                margin-bottom: 16px;
            }

            .event-title {
                font-size: 22px;
                font-weight: 800;
                color: #1f2937;
                margin-bottom: 14px;
            }

            .event-line {
                color: #4b5563;
                margin-bottom: 10px;
                font-size: 15px;
            }

                .event-line i {
                    width: 20px;
                    color: #6366f1;
                }

            .event-actions {
                margin-top: 18px;
                display: flex;
                flex-wrap: wrap;
                gap: 10px;
            }

                .event-actions .btn {
                    border-radius: 12px;
                    font-weight: 700;
                }

            .empty-box {
                background: #ffffff;
                border: 1px dashed #d1d5db;
                border-radius: 22px;
                padding: 36px;
                text-align: center;
                color: #6b7280;
            }

            .footer {
                background: #ffffff;
                border-top: 1px solid #e5e7eb;
                padding: 18px 0;
                text-align: center;
                color: #6b7280;
                font-size: 14px;
                margin-top: 20px;
            }

            @@media (max-width: 991.98px) {
                .navbar-custom {
                    padding: 10px 0;
                }

                .brand-logo-round {
                    width: 74px;
                    height: 74px;
                }

                .navbar-collapse {
                    margin-top: 14px;
                    background: #ffffff;
                    border: 1px solid #eef2f7;
                    border-radius: 18px;
                    padding: 16px;
                    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
                }

                .navbar-nav {
                    align-items: stretch !important;
                    gap: 4px;
                }

                .nav-link-custom {
                    justify-content: flex-start;
                    padding: 12px 14px !important;
                }

                .nav-action-wrap {
                    margin-left: 0;
                    margin-top: 14px;
                    width: 100%;
                    flex-direction: column;
                    align-items: stretch !important;
                }

                    .nav-action-wrap .btn {
                        width: 100%;
                    }

                .banner-content {
                    padding: 40px 24px;
                }

                .banner-title {
                    font-size: 34px;
                }

                .banner-side {
                    min-height: 220px;
                }
            }

            @@media (max-width: 575.98px) {
                .brand-logo-round {
                    width: 64px;
                    height: 64px;
                }
            }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-custom sticky-top">
        <div class="container">

            <a class="navbar-brand brand-wrap" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" alt="Logo" class="brand-logo-round" />
            </a>

            <button class="navbar-toggler custom-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav mx-auto align-items-lg-center">
                    <li class="nav-item">
                        <a class="nav-link nav-link-custom" href="#home">
                            <i class="fas fa-house nav-icon"></i>
                            <span>Home</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-link-custom" href="#features">
                            <i class="fas fa-layer-group nav-icon"></i>
                            <span>Features</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-link-custom" href="#events">
                            <i class="fas fa-calendar-check nav-icon"></i>
                            <span>Events</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-link-custom" href="#howitworks">
                            <i class="fas fa-list-check nav-icon"></i>
                            <span>How It Works</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-link-custom" href="#contact">
                            <i class="fas fa-envelope nav-icon"></i>
                            <span>Contact</span>
                        </a>
                    </li>
                </ul>

                <div class="nav-action-wrap d-flex align-items-center gap-2">
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary nav-btn nav-btn-outline">
                        <i class="fas fa-right-to-bracket me-2"></i>Login
                    </a>

                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary nav-btn nav-btn-fill">
                        <i class="fas fa-user-plus me-2"></i>Register
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <section class="banner-section" id="home">
        <div class="container">
            <div class="banner-card">
                <div class="row g-0 align-items-center">
                    <div class="col-lg-8">
                        <div class="banner-content">
                            <span class="mini-badge">Digital Convocation Registration Portal</span>
                            <h1 class="banner-title">Complete your convocation registration, payment, and QR pass in one place</h1>
                            <p class="banner-text">
                                This platform helps students view active convocation events, register online,
                                complete fee payment, and receive a QR pass for smooth event-day entry.
                                Fast, paperless, and easy to use.
                            </p>

                            <div class="d-flex gap-3 flex-wrap banner-buttons">
                                <a asp-controller="Account" asp-action="Register" class="btn btn-primary">Register Now</a>
                                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">Login</a>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="banner-side">
                            <div class="banner-side-box">
                                <i class="fas fa-qrcode"></i>
                                <h3>Paperless Entry</h3>
                                <p class="mb-0">Register, pay, and access your event pass digitally.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section-wrap" id="features">
        <div class="container">
            <h2 class="section-title">Key Features</h2>
            <p class="section-subtitle">Core features designed for a smooth digital convocation experience.</p>

            <div class="row g-4">
                <div class="col-md-3">
                    <div class="event-card text-center">
                        <div class="event-icon mx-auto"><i class="fas fa-user-plus"></i></div>
                        <div class="event-title fs-5">Online Registration</div>
                        <p class="mb-0 text-muted">Students can create accounts and register for available convocation events online.</p>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="event-card text-center">
                        <div class="event-icon mx-auto"><i class="fas fa-credit-card"></i></div>
                        <div class="event-title fs-5">Secure Payment</div>
                        <p class="mb-0 text-muted">Complete registration payment through the payment gateway with a simple flow.</p>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="event-card text-center">
                        <div class="event-icon mx-auto"><i class="fas fa-qrcode"></i></div>
                        <div class="event-title fs-5">QR Pass Generation</div>
                        <p class="mb-0 text-muted">A QR pass is generated after successful payment confirmation for event-day use.</p>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="event-card text-center">
                        <div class="event-icon mx-auto"><i class="fas fa-check-circle"></i></div>
                        <div class="event-title fs-5">Verification & Distribution</div>
                        <p class="mb-0 text-muted">Staff can verify QR passes and manage event-day distribution operations.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section-wrap" id="events">
        <div class="container">
            <h2 class="section-title">Available Convocation Events</h2>
            <p class="section-subtitle">Choose your event and continue the registration process.</p>

            @if (Model != null && Model.Any())
            {
                <div class="row g-4">
                    @foreach (var item in Model)
                    {
                        var registrationOpen = item.IsActive &&
                                               item.RegistrationStartDate <= now &&
                                               item.RegistrationEndDate >= now;

                        var registrationClosed = now > item.RegistrationEndDate;
                        var registrationNotStarted = now < item.RegistrationStartDate;

                        <div class="col-md-6 col-lg-4">
                            <div class="event-card">
                                <div class="event-icon">
                                    <i class="fas fa-calendar-check"></i>
                                </div>

                                <div class="event-title">@item.EventTitle</div>

                                <div class="event-line">
                                    <i class="fas fa-calendar-days"></i>
                                    Event Date: @item.EventDate.ToString("dd MMM yyyy")
                                </div>

                                <div class="event-line">
                                    <i class="fas fa-location-dot"></i>
                                    Venue: @(string.IsNullOrWhiteSpace(item.Venue) ? "TBA" : item.Venue)
                                </div>

                                <div class="event-line">
                                    <i class="fas fa-clock"></i>
                                    Registration: @item.RegistrationStartDate.ToString("dd MMM yyyy") - @item.RegistrationEndDate.ToString("dd MMM yyyy")
                                </div>

                                <div class="event-line">
                                    <i class="fas fa-user-group"></i>
                                    Max Guests: @item.MaxGuestAllowed
                                </div>

                                <div class="event-line">
                                    <i class="fas fa-money-bill-wave"></i>
                                    Base Fee: ৳@item.BaseFee
                                </div>

                                <div class="mt-3">
                                    @if (registrationOpen)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill">
                                            Registration Open
                                        </span>
                                    }
                                    else if (registrationClosed)
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2 rounded-pill">
                                            Registration Closed
                                        </span>
                                    }
                                    else if (registrationNotStarted)
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2 rounded-pill">
                                            Registration Not Started
                                        </span>
                                    }
                                </div>

                                <div class="event-actions">
                                    @if (registrationOpen)
                                    {
                                        <a asp-controller="Registration"
                                               asp-action="Create"
                                               asp-route-eventId="@item.EventId"
                                               class="btn btn-primary flex-fill">
                                            Register Event
                                        </a>

                                        <a asp-controller="Account"
                                               asp-action="Register"
                                               asp-route-eventId="@item.EventId"
                                               class="btn btn-outline-primary flex-fill">
                                            Create Account
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-secondary flex-fill" disabled>
                                            Unavailable Now
                                        </button>

                                        <a asp-controller="Account"
                                               asp-action="Login"
                                               class="btn btn-outline-secondary flex-fill">
                                            Login
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-box">
                    <h5 class="mb-2">No active events available</h5>
                    <p class="mb-0">Please add active convocation events from the admin panel.</p>
                </div>
            }
        </div>
    </section>

    <section class="section-wrap pt-0" id="howitworks">
        <div class="container">
            <h2 class="section-title">How It Works</h2>
            <p class="section-subtitle">Simple steps for students to complete the whole process.</p>

            <div class="row g-4">
                <div class="col-md-3">
                    <div class="event-card text-center">
                        <div class="event-icon mx-auto"><i class="fas fa-user-plus"></i></div>
                        <div class="event-title fs-5">Create Account</div>
                        <p class="mb-0 text-muted">Create your student account with academic information.</p>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="event-card text-center">
                        <div class="event-icon mx-auto"><i class="fas fa-file-signature"></i></div>
                        <div class="event-title fs-5">Register Event</div>
                        <p class="mb-0 text-muted">Choose an active convocation event and submit registration.</p>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="event-card text-center">
                        <div class="event-icon mx-auto"><i class="fas fa-credit-card"></i></div>
                        <div class="event-title fs-5">Pay Fee</div>
                        <p class="mb-0 text-muted">Complete payment securely through SSLCommerz gateway.</p>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="event-card text-center">
                        <div class="event-icon mx-auto"><i class="fas fa-qrcode"></i></div>
                        <div class="event-title fs-5">Get QR Pass</div>
                        <p class="mb-0 text-muted">Receive your QR pass for easy entry and verification.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section-wrap pt-0" id="contact">
        <div class="container">
            <div class="empty-box">
                <h4 class="mb-2">Need Help?</h4>
                <p class="mb-0">For registration, payment, or QR issues, please contact the convocation administration office.</p>
            </div>
        </div>
    </section>

    <div class="footer">
        <div class="container">
            © 2026 Convocation Management System
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>