@model IEnumerable<Convocation.Entities.Event>

@{
    ViewData["Title"] = "Convocation Management System";
    var now = DateTime.Now;
}

<style>
    .banner-section {
        padding: 28px 0 10px;
    }

    .banner-card {
        background: linear-gradient(135deg, #eef2ff 0%, #ffffff 60%, #f5f3ff 100%);
        border-radius: 30px;
        overflow: hidden;
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
    }

    .banner-content {
        padding: 60px 50px;
    }

    .mini-badge {
        display: inline-block;
        padding: 8px 14px;
        background: rgba(79, 70, 229, 0.10);
        color: #4f46e5;
        border-radius: 999px;
        font-weight: 700;
        font-size: 13px;
        margin-bottom: 18px;
    }

    .banner-title {
        font-size: 44px;
        font-weight: 800;
        color: #111827;
        line-height: 1.2;
        margin-bottom: 16px;
    }

    .banner-text {
        font-size: 16px;
        line-height: 1.8;
        color: #6b7280;
        margin-bottom: 28px;
        max-width: 650px;
    }

    .banner-buttons .btn {
        min-width: 160px;
        border-radius: 14px;
        padding: 12px 20px;
        font-weight: 700;
    }

    .banner-side {
        background: linear-gradient(180deg, #4f46e5, #7c3aed);
        height: 100%;
        min-height: 320px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        text-align: center;
        padding: 30px;
    }

    .banner-side-box i {
        font-size: 54px;
        margin-bottom: 18px;
    }

    .banner-side-box h3 {
        font-weight: 800;
        margin-bottom: 10px;
    }

    .banner-side-box p {
        color: rgba(255,255,255,0.88);
        font-size: 15px;
    }

    .section-wrap {
        padding: 60px 0 70px;
    }

    .section-title {
        font-size: 32px;
        font-weight: 800;
        text-align: center;
        color: #111827;
        margin-bottom: 10px;
    }

    .section-subtitle {
        text-align: center;
        color: #6b7280;
        margin-bottom: 36px;
        font-size: 15px;
    }

    .feature-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 22px;
        padding: 28px 24px;
        height: 100%;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.05);
        transition: 0.25s ease;
    }

        .feature-card:hover {
            transform: translateY(-4px);
        }

    .feature-icon {
        width: 58px;
        height: 58px;
        border-radius: 16px;
        background: #eef2ff;
        color: #4f46e5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        margin-bottom: 16px;
    }

    .feature-title {
        font-size: 20px;
        font-weight: 800;
        color: #1f2937;
        margin-bottom: 12px;
    }

    .feature-text {
        color: #6b7280;
        line-height: 1.7;
        margin-bottom: 0;
    }

    .event-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 22px;
        padding: 24px;
        height: 100%;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.05);
        transition: 0.25s ease;
    }

        .event-card:hover {
            transform: translateY(-4px);
        }

    .event-icon {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        background: #eef2ff;
        color: #4f46e5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        margin-bottom: 16px;
    }

    .event-title {
        font-size: 22px;
        font-weight: 800;
        color: #1f2937;
        margin-bottom: 14px;
    }

    .event-line {
        color: #4b5563;
        margin-bottom: 10px;
        font-size: 15px;
    }

        .event-line i {
            width: 20px;
            color: #6366f1;
        }

    .event-status {
        display: inline-block;
        padding: 7px 14px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        margin-top: 8px;
    }

    .status-open {
        background: #dcfce7;
        color: #166534;
    }

    .status-closed {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-upcoming {
        background: #ede9fe;
        color: #5b21b6;
    }

    .event-actions {
        margin-top: 18px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

        .event-actions .btn {
            border-radius: 12px;
            font-weight: 700;
        }

    .step-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        padding: 28px 22px;
        text-align: center;
        height: 100%;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.05);
    }

    .step-number {
        width: 56px;
        height: 56px;
        margin: 0 auto 16px;
        border-radius: 50%;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 20px;
        box-shadow: 0 10px 20px rgba(79, 70, 229, 0.18);
    }

    .step-title {
        font-size: 20px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 12px;
    }

    .step-text {
        color: #6b7280;
        line-height: 1.7;
        margin-bottom: 0;
    }

    .contact-box {
        background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
        border: 1px solid #e5e7eb;
        border-radius: 26px;
        padding: 36px 30px;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.05);
    }

    .contact-item {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        margin-bottom: 18px;
    }

        .contact-item:last-child {
            margin-bottom: 0;
        }

    .contact-icon {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        background: #eef2ff;
        color: #4f46e5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

    .contact-label {
        font-weight: 800;
        color: #111827;
        margin-bottom: 4px;
    }

    .contact-text {
        color: #6b7280;
        margin-bottom: 0;
    }

    .empty-box {
        background: #ffffff;
        border: 1px dashed #d1d5db;
        border-radius: 22px;
        padding: 36px;
        text-align: center;
        color: #6b7280;
    }

    @@media (max-width: 991.98px) {
        .banner-content {
            padding: 40px 24px;
        }

        .banner-title {
            font-size: 34px;
        }

        .banner-side {
            min-height: 220px;
        }
    }

    @@media (max-width: 575.98px) {
        .banner-title {
            font-size: 28px;
        }

        .section-title {
            font-size: 26px;
        }

        .banner-buttons .btn {
            width: 100%;
        }
    }
</style>

<section class="banner-section" id="home">
    <div class="container">
        <div class="banner-card">
            <div class="row g-0 align-items-center">
                <div class="col-lg-8">
                    <div class="banner-content">
                        <span class="mini-badge">Digital Convocation Registration Portal</span>
                        <h1 class="banner-title">Complete your convocation registration, payment, and QR pass in one place</h1>
                        <p class="banner-text">
                            This platform helps students view active convocation Event, register online,
                            complete fee payment, and receive a QR pass for smooth entry on event day.
                            Fast, professional, and paperless.
                        </p>

                        <div class="d-flex gap-3 flex-wrap banner-buttons">
                            <a asp-controller="Account" asp-action="Register" class="btn btn-primary">
                                <i class="fas fa-user-plus me-2"></i>Register Now
                            </a>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">
                                <i class="fas fa-right-to-bracket me-2"></i>Login
                            </a>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="banner-side">
                        <div class="banner-side-box">
                            <i class="fas fa-qrcode"></i>
                            <h3>Paperless Entry</h3>
                            <p class="mb-0">Register, pay, and access your event pass digitally with QR verification.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-wrap" id="features">
    <div class="container">
        <h2 class="section-title">Platform Features</h2>
        <p class="section-subtitle">Everything needed for a smooth convocation process from registration to entry validation.</p>

        <div class="row g-4">
            <div class="col-md-6 col-xl-3">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-user-graduate"></i>
                    </div>
                    <h4 class="feature-title">Student Registration</h4>
                    <p class="feature-text">
                        Students can create Account, update their profile, and register for active convocation Event online.
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-credit-card"></i>
                    </div>
                    <h4 class="feature-title">Digital Payment</h4>
                    <p class="feature-text">
                        Manage registration fees digitally and keep payment status recorded in one organized system.
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-qrcode"></i>
                    </div>
                    <h4 class="feature-title">QR Pass</h4>
                    <p class="feature-text">
                        Generate and verify QR-based passes for faster and safer entry on the convocation day.
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <h4 class="feature-title">Admin Monitoring</h4>
                    <p class="feature-text">
                        Admin can manage Event, Participant, Payment, passes, and distribution activities centrally.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
     
<section class="section-wrap pt-0" id="Event">
    <div class="container">
        <h2 class="section-title">Upcoming Graduations</h2>
        <p class="section-subtitle">
            Check active and upcoming convocation Event and register within the valid time.
        </p>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">

            @foreach (var item in Model.OrderBy(e => e.EventDate))
            {
                var registrationOpen = item.IsActive &&
                                       item.RegistrationtartDate <= now &&
                                       item.RegistrationEndDate >= now;

                var eventUpcoming = item.EventDate >= now.Date;

                string statusText;
                string statusClass;

                if (registrationOpen)
                {
                    statusText = "Registration Open";
                    statusClass = "status-open";
                }
                else if (eventUpcoming)
                {
                    statusText = "Upcoming";
                    statusClass = "status-upcoming";
                }
                else
                {
                    statusText = "Closed";
                    statusClass = "status-closed";
                }

                <div class="col-md-6 col-xl-4">
                    <div class="event-card">

                        <div class="event-icon">
                            <i class="fas fa-calendar-days"></i>
                        </div>

                        <h3 class="event-title">@item.EventTitle</h3>

                        <div class="event-line">
                            <i class="fas fa-calendar"></i>
                            <strong>Date:</strong> @item.EventDate.ToString("dd MMM yyyy")
                        </div>

                        <div class="event-line">
                            <i class="fas fa-clock"></i>
                            <strong>Registration:</strong>
                            @item.RegistrationtartDate.ToString("dd MMM yyyy")
                            -
                            @item.RegistrationEndDate.ToString("dd MMM yyyy")
                        </div>

                        <div class="event-line">
                            <i class="fas fa-location-dot"></i>
                            <strong>Venue:</strong> @item.Venue
                        </div>

                        <div class="event-line">
                            <i class="fas fa-money-bill-wave"></i>
                            <strong>Base Fee:</strong> ৳@item.BaseFee
                        </div>

                        <div class="event-line">
                            <i class="fas fa-user-group"></i>
                            <strong>Guest Fee:</strong> ৳@item.GuestFee
                        </div>

                        <span class="event-status @statusClass">@statusText</span>

                        <div class="event-actions">
                            @{
                                var isLoggedIn = Context.Session.GetString("UserId") != null;
                            }

                            @if (registrationOpen)
                            {
                                if (isLoggedIn)
                                {
                                    <a asp-controller="Registration"
                                       asp-action="Create"
                                       asp-route-eventId="@item.EventId"
                                       class="btn btn-primary">
                                        <i class="fas fa-file-signature me-2"></i>Enroll
                                    </a>
                                }
                                else
                                {
                                    <a asp-controller="Account"
                                       asp-action="Register"
                                       asp-route-eventId="@item.EventId"
                                       class="btn btn-primary">
                                        <i class="fas fa-file-signature me-2"></i>Enroll
                                    </a>
                                }
                            }
                            else
                            {
                                <button class="btn btn-outline-secondary" disabled>
                                    <i class="fas fa-ban me-2"></i>Registration Closed
                                </button>
                            }
                        </div>

                    </div>
                </div>
            }

        </div>
    }
    else
    {
        <div class="empty-box">
            <i class="fas fa-calendar-xmark fa-2x mb-3 text-secondary"></i>
            <h5 class="fw-bold">No Event available right now</h5>
            <p class="mb-0">
                Upcoming convocation Event will appear here once they are created by the administration.
            </p>
        </div>
    }
</div>

</section>

<section class="section-wrap pt-0" id="howitworks">
    <div class="container">
        <h2 class="section-title">How It Works</h2>
        <p class="section-subtitle">A simple process for students from account creation to event-day participation.</p>

        <div class="row g-4">
            <div class="col-md-6 col-xl-3">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <h4 class="step-title">Create Account</h4>
                    <p class="step-text">Register with your student and personal information to access the participant portal.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="step-card">
                    <div class="step-number">2</div>
                    <h4 class="step-title">Choose Event</h4>
                    <p class="step-text">View active convocation Event and submit your registration during the open period.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="step-card">
                    <div class="step-number">3</div>
                    <h4 class="step-title">Complete Payment</h4>
                    <p class="step-text">Pay your registration fee and keep track of your payment status from your account.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="step-card">
                    <div class="step-number">4</div>
                    <h4 class="step-title">Use QR Pass</h4>
                    <p class="step-text">Receive your QR pass and use it for verification and entry during the convocation event.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-wrap pt-0" id="contact">
    <div class="container">
        <h2 class="section-title">Contact</h2>
        <p class="section-subtitle">Need help regarding registration, payment, or event details? Reach out here.</p>

        <div class="contact-box">
            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div>
                            <div class="contact-label">Email</div>
                            <p class="contact-text">convocation@university.edu</p>
                        </div>
                    </div>

                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-phone"></i>
                        </div>
                        <div>
                            <div class="contact-label">Phone</div>
                            <p class="contact-text">+880 1XXXXXXXXX</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-location-dot"></i>
                        </div>
                        <div>
                            <div class="contact-label">Office</div>
                            <p class="contact-text">Convocation Management Office, Main Campus</p>
                        </div>
                    </div>

                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div>
                            <div class="contact-label">Office Hours</div>
                            <p class="contact-text">Sunday to Thursday, 9:00 AM - 5:00 PM</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>