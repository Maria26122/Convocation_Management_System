@model Convocation.Entities.RolePermission

@{
    ViewData["Title"] = "Assign Permission";
}

<h2>Assign Permission to Role</h2>

<form asp-action="Create" method="post">

    <div class="form-group mb-3">
        <label>Role</label>
        <select asp-for="RoleId" class="form-control" asp-items="ViewBag.RoleId"></select>
    </div>

    <div class="form-group mb-3">
        <label>Permission</label>
        <select asp-for="PermissionId" class="form-control" asp-items="ViewBag.PermissionId"></select>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>

</form>

@if (!ViewData.ModelState.IsValid)
{
    <div class="text-danger mt-2">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@error.ErrorMessage</div>
        }
    </div>
}