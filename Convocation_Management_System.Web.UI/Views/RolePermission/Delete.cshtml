@model Convocation.Entities.RolePermission

@{
    ViewData["Title"] = "Delete Role Permission";
}

<h2>Delete Confirmation</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this mapping?
</div>

<div>
    <p><strong>Role:</strong> @Model.Role?.RoleName</p>
    <p><strong>Permission:</strong> @Model.Permission?.PermissionName</p>
</div>

<form asp-action="DeleteConfirmed" method="post">

    <input type="hidden" name="roleId" value="@Model.RoleId" />
    <input type="hidden" name="permissionId" value="@Model.PermissionId" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>

</form>