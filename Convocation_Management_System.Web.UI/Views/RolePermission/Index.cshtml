@model IEnumerable<Convocation.Entities.RolePermission>

@{
    ViewData["Title"] = "Role Permissions";
}

<h2>Role Permissions</h2>

<a class="btn btn-primary mb-3" asp-action="Create">Add New</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Role</th>
            <th>Permission</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Role?.RoleName</td>
                <td>@item.Permission?.PermissionName</td>

                <td>
                    <a asp-action="Edit"
                       asp-route-roleId="@item.RoleId"
                       asp-route-permissionId="@item.PermissionId"
                       class="btn btn-sm btn-warning">
                        Edit
                    </a>

                    <a asp-action="Details"
                       asp-route-roleId="@item.RoleId"
                       asp-route-permissionId="@item.PermissionId"
                       class="btn btn-sm btn-info">
                        Details
                    </a>

                    <a asp-action="Delete"
                       asp-route-roleId="@item.RoleId"
                       asp-route-permissionId="@item.PermissionId"
                       class="btn btn-sm btn-danger">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>