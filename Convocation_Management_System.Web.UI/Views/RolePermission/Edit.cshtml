@model Convocation.Entities.RolePermission

@{
    ViewData["Title"] = "Edit Role Permission";
}

<h2>Edit Role Permission</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="RoleId" />
    <input type="hidden" asp-for="PermissionId" />

    <div class="form-group mb-3">
        <label>Role</label>
        <select asp-for="RoleId" class="form-control" asp-items="ViewBag.RoleId" disabled></select>
    </div>

    <div class="form-group mb-3">
        <label>Permission</label>
        <select asp-for="PermissionId" class="form-control" asp-items="ViewBag.PermissionId"></select>
    </div>

    <button type="submit" class="btn btn-primary">Update</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>

</form>