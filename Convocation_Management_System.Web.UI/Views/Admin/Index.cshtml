@model Convocation_Management_System.Web.UI.Models.AdminDashboardViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<div class="welcome-box mb-4">
    <h4 class="mb-2">Convocation System Overview</h4>
    <p class="text-soft">
        Manage Event, participant Registration, Payment, QR passes,
        and distribution activities from one centralized admin dashboard.
    </p>
</div>

<div class="row g-4 mb-4">

    <div class="col-md-6 col-xl-4">
        <div class="stats-card">
            <i class="fas fa-user-graduate icon"></i>
            <h6>Total Participant</h6>
            <h2>@Model.TotalParticipant</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="stats-card">
            <i class="fas fa-calendar-days icon"></i>
            <h6>Total Event</h6>
            <h2>@Model.TotalEvent</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="stats-card">
            <i class="fas fa-file-signature icon"></i>
            <h6>Total Registration</h6>
            <h2>@Model.TotalRegistration</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="stats-card">
            <i class="fas fa-users icon"></i>
            <h6>Total Guest</h6>
            <h2>@Model.TotalGuest</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="stats-card">
            <i class="fas fa-money-check-dollar icon"></i>
            <h6>Total Payment</h6>
            <h2>@Model.TotalPayment</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="stats-card">
            <i class="fas fa-qrcode icon"></i>
            <h6>Total QR Passes</h6>
            <h2>@Model.TotalQrPass</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="stats-card">
            <i class="fas fa-box-open icon"></i>
            <h6>Distribution Logs</h6>
            <h2>@Model.TotalDistributionLog</h2>
        </div>
    </div>

</div>

<div class="dashboard-grid mt-4">

    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
        <div class="stat-title">Paid Registration</div>
        <div class="stat-value">@Model.ApprovedRegistration</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-clock"></i></div>
        <div class="stat-title">Pending Registration</div>
        <div class="stat-value">@Model.PendingRegistration</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-times-circle"></i></div>
        <div class="stat-title">Rejected Registration</div>
        <div class="stat-value">@Model.RejectedRegistration</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-money-check-alt"></i></div>
        <div class="stat-title">Paid Payment</div>
        <div class="stat-value">@Model.PaidPayment</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-hourglass-half"></i></div>
        <div class="stat-title">Pending Payment</div>
        <div class="stat-value">@Model.PendingPayment</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-ban"></i></div>
        <div class="stat-title">Failed Payment</div>
        <div class="stat-value">@Model.FailedPayment</div>
    </div>

</div>