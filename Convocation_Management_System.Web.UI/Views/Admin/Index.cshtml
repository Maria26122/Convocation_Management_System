@model Convocation_Management_System.Web.UI.Models.AdminDashboardViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<div class="welcome-box mb-4">
    <h4 class="mb-2">Convocation System Overview</h4>
    <p class="text-soft">
        Manage events, participant registrations, payments, QR passes,
        and distribution activities from one centralized admin dashboard.
    </p>
</div>

<div class="row g-4 mb-4">

    <div class="col-md-6 col-xl-4">
        <div class="stats-card">
            <i class="fas fa-user-graduate icon"></i>
            <h6>Total Participants</h6>
            <h2>@Model.TotalParticipants</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="stats-card">
            <i class="fas fa-calendar-days icon"></i>
            <h6>Total Events</h6>
            <h2>@Model.TotalEvents</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="stats-card">
            <i class="fas fa-file-signature icon"></i>
            <h6>Total Registrations</h6>
            <h2>@Model.TotalRegistrations</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="stats-card">
            <i class="fas fa-users icon"></i>
            <h6>Total Guests</h6>
            <h2>@Model.TotalGuests</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="stats-card">
            <i class="fas fa-money-check-dollar icon"></i>
            <h6>Total Payments</h6>
            <h2>@Model.TotalPayments</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="stats-card">
            <i class="fas fa-qrcode icon"></i>
            <h6>Total QR Passes</h6>
            <h2>@Model.TotalQrPasses</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="stats-card">
            <i class="fas fa-box-open icon"></i>
            <h6>Distribution Logs</h6>
            <h2>@Model.TotalDistributionLogs</h2>
        </div>
    </div>

</div>

<div class="dashboard-grid mt-4">

    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
        <div class="stat-title">Approved Registrations</div>
        <div class="stat-value">@Model.ApprovedRegistrations</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-clock"></i></div>
        <div class="stat-title">Pending Registrations</div>
        <div class="stat-value">@Model.PendingRegistrations</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-times-circle"></i></div>
        <div class="stat-title">Rejected Registrations</div>
        <div class="stat-value">@Model.RejectedRegistrations</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-money-check-alt"></i></div>
        <div class="stat-title">Paid Payments</div>
        <div class="stat-value">@Model.PaidPayments</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-hourglass-half"></i></div>
        <div class="stat-title">Pending Payments</div>
        <div class="stat-value">@Model.PendingPayments</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-ban"></i></div>
        <div class="stat-title">Failed Payments</div>
        <div class="stat-value">@Model.FailedPayments</div>
    </div>

</div>