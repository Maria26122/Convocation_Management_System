@model Convocation_Management_System.Web.UI.Models.AdminReportsViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Reports";
}

<div class="welcome-box mb-4">
    <h4 class="mb-2">System Reports</h4>
    <p class="text-soft">
        View summary statistics and event-wise report details for the convocation management system.
    </p>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="stats-card">
            <i class="fas fa-user-graduate icon"></i>
            <h6>Total Participants</h6>
            <h2>@Model.TotalParticipants</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="stats-card">
            <i class="fas fa-calendar-days icon"></i>
            <h6>Total Events</h6>
            <h2>@Model.TotalEvents</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="stats-card">
            <i class="fas fa-file-signature icon"></i>
            <h6>Total Registrations</h6>
            <h2>@Model.TotalRegistrations</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="stats-card">
            <i class="fas fa-users icon"></i>
            <h6>Total Guests</h6>
            <h2>@Model.TotalGuests</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="stats-card">
            <i class="fas fa-money-check-dollar icon"></i>
            <h6>Total Payments</h6>
            <h2>@Model.TotalPayments</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="stats-card">
            <i class="fas fa-qrcode icon"></i>
            <h6>Total QR Passes</h6>
            <h2>@Model.TotalQrPasses</h2>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="stats-card">
            <i class="fas fa-box-open icon"></i>
            <h6>Distribution Logs</h6>
            <h2>@Model.TotalDistributionLogs</h2>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <h5 class="mb-3">Registration Summary</h5>
                <table class="table table-bordered align-middle">
                    <tr>
                        <th>Approved / Confirmed</th>
                        <td>@Model.ApprovedRegistrations</td>
                    </tr>
                    <tr>
                        <th>Pending</th>
                        <td>@Model.PendingRegistrations</td>
                    </tr>
                    <tr>
                        <th>Rejected</th>
                        <td>@Model.RejectedRegistrations</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <h5 class="mb-3">Payment Summary</h5>
                <table class="table table-bordered align-middle">
                    <tr>
                        <th>Paid</th>
                        <td>@Model.PaidPayments</td>
                    </tr>
                    <tr>
                        <th>Pending</th>
                        <td>@Model.PendingPayments</td>
                    </tr>
                    <tr>
                        <th>Failed</th>
                        <td>@Model.FailedPayments</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body">
        <h5 class="mb-3">Event-wise Report</h5>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead>
                    <tr style="background-color:#212529; color:#ffffff;">
                        <th>Event Title</th>
                        <th>Event Date</th>
                        <th>Total Registrations</th>
                        <th>Total Guests</th>
                        <th>Total Collected Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.EventReports != null && Model.EventReports.Any())
                    {
                        @foreach (var item in Model.EventReports)
                        {
                            <tr>
                                <td>@item.EventTitle</td>
                                <td>@item.EventDate.ToString("dd MMM yyyy")</td>
                                <td>@item.RegistrationCount</td>
                                <td>@item.GuestCount</td>
                                <td>@item.TotalCollectedAmount.ToString("0.00")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">No report data available.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>