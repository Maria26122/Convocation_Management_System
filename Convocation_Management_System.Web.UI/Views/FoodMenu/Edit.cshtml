@model Convocation.Entities.FoodMenu

@{
    ViewData["Title"] = "Edit Food Menu";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h3>Edit Food Menu</h3>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="FoodMenuId" />

    <div class="form-group mb-2">
        <label>Menu Name</label>
        <input asp-for="MenuName" class="form-control" />
    </div>

    <div class="form-group mb-2">
        <label>Menu Items</label>
        <textarea asp-for="MenuItems" class="form-control" rows="4"></textarea>
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label class="form-check-label">Active</label>
    </div>

    <button type="submit" class="btn btn-primary">Update</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>