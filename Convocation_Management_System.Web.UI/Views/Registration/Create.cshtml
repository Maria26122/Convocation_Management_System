@model Convocation.Entities.Registration

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Create Registration";

    var events = ViewBag.Event as IEnumerable<dynamic>;
    var selectedEventId = ViewBag.SelectedEventId ?? Model.EventId;
}

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="row g-3">

        <!-- EVENT -->
        <div class="col-md-6">
            <label>Event</label>

            <select asp-for="EventId" class="form-select" id="EventSelect">
                <option value="">Select Event</option>

                @foreach (var item in events)
                {
                    <option value="@item.EventId"
                            data-basefee="@item.BaseFee"
                            data-guestfee="@item.GuestFee"
                            selected="@(item.EventId == selectedEventId)">
                        @item.EventTitle
                    </option>
                }
            </select>
        </div>

        <!-- GUEST COUNT -->
        <div class="col-md-6">
            <label>Guest Count</label>
            <input asp-for="GuestCount"
                   class="form-control"
                   id="GuestCount"
                   min="0" />
        </div>

        <!-- TOTAL -->
        <div class="col-md-6">
            <label>Total Amount</label>
            <input asp-for="TotalAmount"
                   class="form-control"
                   id="TotalAmount"
                   readonly />
        </div>

        <!-- STATUS -->
        <input type="hidden" asp-for="RegistrationStatus" value="Pending" />

    </div>

    <button type="submit" class="btn btn-primary mt-3">
        Save & Pay
    </button>
</form>