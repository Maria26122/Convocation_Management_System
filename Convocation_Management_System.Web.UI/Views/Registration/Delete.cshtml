@model Convocation.Entities.Registration

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Delete Registration";
}

<div class="delete-card">
    <h3 class="delete-title mb-2 text-danger">Delete Registration</h3>
    <p class="text-soft">Are you sure you want to delete this registration?</p>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="label-title">Participant</div>
            <div class="value-text">@Model.Participant?.StudentId</div>
        </div>

        <div class="col-md-6">
            <div class="label-title">Event</div>
            <div class="value-text">@Model.Event?.EventTitle</div>
        </div>

        <div class="col-md-6">
            <div class="label-title">Guest Count</div>
            <div class="value-text">@Model.GuestCount</div>
        </div>

        <div class="col-md-6">
            <div class="label-title">Status</div>
            <div class="value-text">
                @if (Model.RegistrationStatus == "Pending")
                {
                    <span class="badge-status badge-warning">Pending</span>
                }
                else if (Model.RegistrationStatus == "Confirmed")
                {
                    <span class="badge-status badge-success">Confirmed</span>
                }
                else
                {
                    <span class="badge-status badge-danger">Rejected</span>
                }
            </div>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-4">
        <input type="hidden" asp-for="RegistrationId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>