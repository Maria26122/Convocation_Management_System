@model Convocation_Management_System.Web.UI.Models.ParticipantDashboardViewModel

@{
    Layout = "~/Views/Shared/_ParticipantLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">

    <h2 class="mb-4">Welcome, @Model.FullName 👋</h2>

    <div class="mt-4">

        @if (Model.RegistrationId == null)
        {
            <a asp-controller="Registration"
               asp-action="Create"
               class="btn btn-primary">
                🚀 Register Now
            </a>
        }

        else if (Model.RegistrationStatus == "Pending")
        {
            <div class="alert alert-warning">
                ⏳ Your registration is under review
            </div>
        }

        else if (Model.RegistrationStatus == "Rejected")
        {
            <div class="alert alert-danger">
                ❌ Registration rejected. Contact admin.
            </div>
        }

        else if (Model.RegistrationStatus == "Approved" &&
                 Model.PaymentStatus != "Paid")
        {
            <a asp-controller="Payment"
               asp-action="PayNow"
               asp-route-registrationId="@Model.RegistrationId"
               class="btn btn-warning">
                💳 Pay Now
            </a>
        }

        else if (Model.PaymentStatus == "Paid")
        {
            <div class="d-flex gap-2 flex-wrap">

                <a asp-controller="Participant"
                   asp-action="MyQrPass"
                   asp-route-registrationId="@Model.RegistrationId"
                   class="btn btn-success">
                    🎫 View QR Pass
                </a>

                <a asp-controller="Participant"
                   asp-action="MyRegistration"
                   class="btn btn-outline-primary">
                    📄 View Registration
                </a>

                <a asp-controller="Participant"
                   asp-action="MyPayment"
                   class="btn btn-outline-success">
                    💰 Payment Details
                </a>

            </div>
        }

    </div>

</div>