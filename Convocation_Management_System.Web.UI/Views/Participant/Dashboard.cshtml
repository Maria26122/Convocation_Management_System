@{
    Layout = "~/Views/Shared/_ParticipantLayout.cshtml";
}

<h3 class="mb-4">Student Dashboard</h3>

<div class="row">

    <div class="col-md-3">
        <div class="card shadow-sm p-3">
            <h6>Registration</h6>
            <h3>@ViewBag.TotalRegistration</h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm p-3">
            <h6>Payment</h6>
            <h3>@ViewBag.TotalPayment</h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm p-3">
            <h6>QR Pass</h6>
            <h3>@ViewBag.TotalQR</h3>
        </div>
    </div>

</div>