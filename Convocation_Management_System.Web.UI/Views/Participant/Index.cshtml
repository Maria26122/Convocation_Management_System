@model IEnumerable<Convocation.Entities.Participant>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Participants";
}

<div class="page-card">
    <div class="page-header">
        <h3>Participant List</h3>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i> Add New Participant
        </a>
    </div>

    <div class="table-responsive">
        <table class="table align-middle table-hover">
            <thead>
                <tr>
                    <th>Student ID</th>
                    <th>User Account ID</th>
                    <th>Department</th>
                    <th>Program</th>
                    <th>Session</th>
                    <th>Eligibility</th>
                    <th style="width: 220px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.StudentId</td>
                            <td>@item.UserAccountId</td>
                            <td>@item.Department</td>
                            <td>@item.Program</td>
                            <td>@item.Session</td>
                            <td>
                                @if (item.IsEligible)
                                {
                                    <span class="badge-status badge-success">Eligible</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-danger">Not Eligible</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.ParticipantId" class="btn btn-sm btn-info text-white">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.ParticipantId" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.ParticipantId" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-soft">No participants found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>