@model IEnumerable<Convocation.Entities.Participant>

@{
    ViewData["Title"] = "Participant Dashboard";
}

<h2>Participant Dashboard</h2>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">No participant data found.</div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Participant ID</th>
                <th>Student ID</th>
                <th>Department</th>
                <th>Program</th>
                <th>Session</th>
                <th>Eligible</th>
                <th>User Email</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ParticipantId</td>
                    <td>@item.StudentId</td>
                    <td>@item.Department</td>
                    <td>@item.Program</td>
                    <td>@item.Session</td>
                    <td>@item.IsEligible</td>
                    <td>@item.UserAccount?.Email</td>
                </tr>
            }
        </tbody>
    </table>
}