@model Convocation.Entities.Participant

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Delete Participant";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white">
        <h4 class="mb-0 text-danger">Delete Participant</h4>
    </div>
    <div class="card-body">
        <h5 class="mb-3">Are you sure you want to delete this participant?</h5>

        <dl class="row">
            <dt class="col-sm-3">Full Name</dt>
            <dd class="col-sm-9">@Model.UserAccount?.FullName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.UserAccount?.Email</dd>

            <dt class="col-sm-3">Student ID</dt>
            <dd class="col-sm-9">@Model.StudentId</dd>

            <dt class="col-sm-3">Department</dt>
            <dd class="col-sm-9">@Model.Department</dd>

            <dt class="col-sm-3">Program</dt>
            <dd class="col-sm-9">@Model.Program</dd>

            <dt class="col-sm-3">Session</dt>
            <dd class="col-sm-9">@Model.Session</dd>
        </dl>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ParticipantId" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
        </form>
    </div>
</div>