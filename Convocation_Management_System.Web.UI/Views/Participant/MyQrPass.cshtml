@model Convocation.Entities.QrPass

@{
    ViewData["Title"] = "My QR Pass";
    Layout = "~/Views/Shared/_ParticipantLayout.cshtml";
}

<div class="container mt-4 text-center">

    <h2 class="mb-4">My QR Pass</h2>

    @if (Model == null)
    {
        <div class="alert alert-warning">
            QR is not generated yet. Please complete payment first.
        </div>
    }
    else
    {
        <div class="card shadow p-4 d-inline-block">

            <img src="@Url.Content(Model.QrImagePath)"
                 alt="QR Code"
                 style="width:250px;height:250px;" />

            <hr />

            <p><b>Registration ID:</b> @Model.RegistrationId</p>

            <input class="form-control"
                   readonly
                   value="@Model.QrCodeText" />
        </div>
    }
</div>