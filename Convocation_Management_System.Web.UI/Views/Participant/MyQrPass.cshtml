@model Convocation.Entities.QrPass

@{
    ViewData["Title"] = "My QR Pass";
    Layout = "~/Views/Shared/_ParticipantLayout.cshtml";
}

<div class="content-card text-center">
    <h4 class="mb-4">My QR Pass</h4>

    @if (Model == null)
    {
        <div class="alert alert-warning">QR not generated yet.</div>
    }
    else
    {
        <div class="mb-3">
            <i class="fas fa-qrcode fa-4x text-primary"></i>
        </div>

        <h5>@(Model?.QrCodeText ?? "QR Not Available")</h5>

        <p class="text-muted">
            Issued: @(Model?.IssuedAt.ToString("dd MMM yyyy hh:mm tt") ?? "N/A")
        </p>

        <p>
            Status:
            @(Model?.IsUsed == true ? "Used" : "Ready")
        </p>
    }
</div>