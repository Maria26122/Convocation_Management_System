@model Convocation.Entities.QrPass

@{
    ViewData["Title"] = "My QR Pass";
    Layout = "~/Views/Shared/_ParticipantLayout.cshtml";
}

<div class="container mt-4 text-center">

    <h2 class="mb-4">My QR Pass</h2>

    @if (Model == null || string.IsNullOrEmpty(Model.QrImagePath))
    {
        <div class="alert alert-warning">
            QR is not generated yet. Please complete your registration and payment.
        </div>

        <a asp-controller="Registration"
           asp-action="Index"
           class="btn btn-primary mt-2">
            Go to My Registrations
        </a>
    }
    else
    {
        <div class="card shadow p-4 d-inline-block">

            <img src="@Model.QrImagePath"
                 alt="QR Code"
                 style="width:250px;height:250px;" />

            <hr />

            <p><b>Registration ID:</b> @Model.RegistrationId</p>
            <p><b>QR Text:</b> @Model.QrCodeText</p>

        </div>

        <div class="mt-3">
            <a asp-controller="Registration"
               asp-action="Index"
               class="btn btn-outline-secondary">
                Back
            </a>
        </div>
    }
</div>