@model Convocation.Entities.Registration

@{
    ViewData["Title"] = "My Registration";
    Layout = "~/Views/Shared/_ParticipantLayout.cshtml";
}

<div class="soft-card p-4">
    <h3 class="fw-bold mb-4">My Registration</h3>

    @if (Model == null)
    {
        <div class="alert alert-warning">No registration found.</div>
    }
    else
    {
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <label class="fw-bold">Registration ID</label>
                <div class="form-control">@Model.RegistrationId</div>
            </div>

            <div class="col-md-6">
                <label class="fw-bold">Status</label>
                <div class="form-control">@Model.RegistrationStatus</div>
            </div>
        </div>

        @if (Model.RegistrationStatus != "Confirmed")
        {
            <form asp-controller="Payment" asp-action="StartConvocationPayment" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="registrationId" value="@Model.RegistrationId" />
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fas fa-credit-card me-2"></i> Pay Convocation Fee
                </button>
            </form>
        }
    }
</div>