@model Convocation.Entities.Registration

@{
    ViewData["Title"] = "My Registration";
    Layout = "~/Views/Shared/_ParticipantLayout.cshtml";

    var status = (Model?.RegistrationStatus ?? "").Trim().ToLower();
    var isPaid = status == "paid" || status == "confirmed";
}

<div class="content-card">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <h4 class="mb-0">My Registration</h4>

        @if (Model != null && Model.RegistrationId > 0)
        {
            if (!isPaid)
            {
                <form asp-controller="Participant"
                      asp-action="SubmitPayment"
                      method="post">

                    <input type="hidden"
                           name="registrationId"
                           value="@Model.RegistrationId" />

                   
                </form>
            }
            else
            {
                <a asp-controller="Participant"
                       asp-action="MyQrPass"
                       class="btn btn-primary">
                    <i class="fas fa-qrcode me-2"></i>View QR Pass
                </a>
            }
        }
    </div>

    @if (Model == null)
    {
        <div class="alert alert-warning">No registration found.</div>
    }
    else
    {
        <div class="row g-4">

            <div class="col-md-6">
                <label class="text-muted">Registration ID</label>
                <div class="fw-bold">@Model.RegistrationId</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Status</label>
                <div class="fw-bold">
                    @if (isPaid)
                    {
                        <span class="badge bg-success px-3 py-2">@Model.RegistrationStatus</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark px-3 py-2">@Model.RegistrationStatus</span>
                    }
                </div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Registration Date</label>
                <div class="fw-bold">@Model.RegistrationDate.ToString("dd MMM yyyy")</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Event</label>
                <div class="fw-bold">@Model.Event?.EventTitle</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Event Date</label>
                <div class="fw-bold">@(Model.Event?.EventDate.ToString("dd MMM yyyy") ?? "TBA")</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Venue</label>
                <div class="fw-bold">@(!string.IsNullOrWhiteSpace(Model.Event?.Venue) ? Model.Event.Venue : "TBA")</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Guest Count</label>
                <div class="fw-bold">@Model.GuestCount</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Total Amount</label>
                <div class="fw-bold">৳@Model.TotalAmount</div>
            </div>

        </div>

        <hr class="my-4" />

        <div class="d-flex gap-2 flex-wrap">

            @if (!isPaid)
            {
                <a asp-controller="Participant"
                   asp-action="MyPayment"
                   class="btn btn-success">

                    Pay Now
                </a>
            }
            else
            {
                <a asp-controller="Participant"
                   asp-action="MyPayment"
                   class="btn btn-outline-success">

                    <i class="fas fa-receipt me-2"></i>View Payment
                </a>

                <a asp-controller="Participant"
                   asp-action="MyQrPass"
                   class="btn btn-outline-primary">

                    <i class="fas fa-qrcode me-2"></i>View QR Pass
                </a>
            }

            <a asp-controller="Guest"
               asp-action="Index"
               class="btn btn-outline-secondary">

                <i class="fas fa-users me-2"></i>My Guest
            </a>

        </div>
    }
</div>