@model Convocation.Entities.Payment

@{
    ViewData["Title"] = "My Payment";
}

<h3>Payment Page</h3>

@if (Model == null)
{
    <div class="alert alert-warning">
        No payment found for your registration.
    </div>
}
else
{
    <div>
        <h4>Payment Status: @Model.PaymentStatus</h4>
        <p>Amount: @Model.PaidAmount</p>
        <p>Transaction: @Model.TransactionId</p>
    </div>
}

        @if (Model.PaymentStatus == "Pending")
        {
            <a class="btn btn-primary"
               href="@Url.Action("PayWithSSL", "Payment",
                                  new { registrationId = Model.RegistrationId, amount = Model.PaidAmount })">
                Pay with SSLCommerz
            </a>

            <hr />

            <form asp-action="Submit" method="post">
                <input type="hidden" name="registrationId" value="@Model.RegistrationId" />

                <label>Transaction ID</label>
                <input type="text" name="transactionId" class="form-control" required />

                <br />

                <button class="btn btn-success">
                    Submit Manual Payment
                </button>
            </form>
        }
        else
        {
            <div class="alert alert-success">
                Payment Completed
            </div>

            <a asp-controller="Participant"
               asp-action="MyRegistration"
               class="btn btn-primary">
                Back to Registration
            </a>
        }

    </div>
}