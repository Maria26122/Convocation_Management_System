@model Convocation.Entities.Payment

@{
    ViewData["Title"] = "My Payment";
    Layout = "~/Views/Shared/_ParticipantLayout.cshtml";
}

<div class="content-card">
    <h4 class="mb-4">My Payment</h4>

    @if (Model == null)
    {
        <div class="alert alert-warning">No payment found.</div>
    }
    else
    {
        <div class="row g-4">

            <div class="col-md-6">
                <label class="text-muted">Payment ID</label>
                <div class="fw-bold">@Model.PaymentId</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Registration ID</label>
                <div class="fw-bold">@Model.RegistrationId</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Amount</label>
                <div class="fw-bold">৳@(Model?.PaidAmount.ToString() ?? "0")</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Status</label>
                <div class="fw-bold">@(Model?.PaymentStatus ?? "N/A")</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Payment Date</label>
                <div class="fw-bold">@(Model?.PaymentDate?.ToString("dd MMM yyyy") ?? "N/A")</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Transaction ID</label>
                <div class="fw-bold">@(!string.IsNullOrWhiteSpace(Model?.TransactionId) ? Model.TransactionId : "N/A")</div>
            </div>

        </div>
    }
</div>