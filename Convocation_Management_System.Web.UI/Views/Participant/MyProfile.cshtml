@model Convocation.Entities.Participant

@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_ParticipantLayout.cshtml";
}

<div class="content-card">
    <h4 class="mb-4">My Profile</h4>

    @if (Model == null)
    {
        <div class="alert alert-warning">Profile not found.</div>
    }
    else
    {
        <div class="row g-4">

            <div class="col-md-6">
                <label class="text-muted">Full Name</label>
                <div class="fw-bold">@(!string.IsNullOrWhiteSpace(Model?.UserAccount?.FullName) ? Model.UserAccount.FullName : "N/A")</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Email</label>
                <div class="fw-bold">@(!string.IsNullOrWhiteSpace(Model?.UserAccount?.Email) ? Model.UserAccount.Email : "N/A")</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Phone</label>
                <div class="fw-bold">@(!string.IsNullOrWhiteSpace(Model?.UserAccount?.Phone) ? Model.UserAccount.Phone : "N/A")</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Eligibility</label>
                <div class="fw-bold">
                    @(Model?.IsEligible == true ? "Eligible" : "Not Eligible")
                </div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Student ID</label>
                <div class="fw-bold">@(!string.IsNullOrWhiteSpace(Model?.StudentId) ? Model.StudentId : "N/A")</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Department</label>
                <div class="fw-bold">@(!string.IsNullOrWhiteSpace(Model?.Department) ? Model.Department : "N/A")</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Program</label>
                <div class="fw-bold">@(!string.IsNullOrWhiteSpace(Model?.Program) ? Model.Program : "N/A")</div>
            </div>

            <div class="col-md-6">
                <label class="text-muted">Session</label>
                <div class="fw-bold">@(!string.IsNullOrWhiteSpace(Model?.Session) ? Model.Session : "N/A")</div>
            </div>

        </div>
    }
</div>