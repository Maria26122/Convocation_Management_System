@model IEnumerable<Convocation.Entities.Permission>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Permissions";
}
<div class="table-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="form-title mb-0">Permission List</h3>
        <a asp-action="Create" class="btn btn-primary">Add Permission</a>
    </div>
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }
    <table class="table table-bordered table-hover">
        <thead><tr><th>Permission Name</th><th style="width:220px;">Actions</th></tr></thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.PermissionName</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.PermissionId" class="btn btn-sm btn-info">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.PermissionId" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.PermissionId" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="2" class="text-center">No permissions found.</td></tr>
            }
        </tbody>
    </table>
</div>