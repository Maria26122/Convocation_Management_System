@model Convocation.Entities.Permission
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Delete Permission";
}
<div class="form-card">
    <h3 class="form-title mb-4 text-danger">Delete Permission</h3>
    <p>Are you sure you want to delete this permission?</p>
    <dl class="row">
        <dt class="col-sm-3">Permission Name</dt>
        <dd class="col-sm-9">@Model.PermissionName</dd>
    </dl>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="PermissionId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>