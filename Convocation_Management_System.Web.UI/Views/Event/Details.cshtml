@model Convocation.Entities.Event

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Event Details";
}

<div class="details-card">
    <h3 class="details-title mb-4">Event Details</h3>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="label-title">Event Title</div>
            <div class="value-text">@Model.EventTitle</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Venue</div>
            <div class="value-text">@Model.Venue</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Event Date</div>
            <div class="value-text">@Model.EventDate.ToString("dd MMM yyyy")</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Registration Start Date</div>
            <div class="value-text">@Model.RegistrationStartDate.ToString("dd MMM yyyy")</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Registration End Date</div>
            <div class="value-text">@Model.RegistrationEndDate.ToString("dd MMM yyyy")</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Base Fee</div>
            <div class="value-text">@Model.BaseFee</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Guest Fee</div>
            <div class="value-text">@Model.GuestFee</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Max Guest Allowed</div>
            <div class="value-text">@Model.MaxGuestAllowed</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Status</div>
            <div class="value-text">
                @if (Model.IsActive)
                {
                    <span class="badge-status badge-success">Active</span>
                }
                else
                {
                    <span class="badge-status badge-danger">Inactive</span>
                }
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="Edit" asp-route-id="@Model.EventId" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>