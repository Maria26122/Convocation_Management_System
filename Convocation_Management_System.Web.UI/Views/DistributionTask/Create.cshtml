@model Convocation_Management_System.Web.UI.Models.DistributionTaskViewModel

@{
    ViewData["Title"] = "Create Task";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">

    <h2>Create Distribution Task</h2>

    <form asp-action="Create" method="post">

        <div class="mb-2">
            <label>Title</label>
            <input asp-for="TaskTitle" class="form-control" />
        </div>

        <div class="mb-2">
            <label>Description</label>
            <input asp-for="Description" class="form-control" />
        </div>

        <div class="mb-2">
            <label>Event</label>
            <select asp-for="EventId" asp-items="Model.Events" class="form-control"></select>
        </div>

        <div class="alert alert-info mt-3">
            Staff assignment will be done separately from Staff Task module.
        </div>

        <button type="submit" class="btn btn-success">
            Create Task
        </button>

    </form>

</div>