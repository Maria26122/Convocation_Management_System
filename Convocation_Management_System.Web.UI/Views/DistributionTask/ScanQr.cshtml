@{
    ViewData["Title"] = "QR Scanner";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

<style>
    .scanner-box {
        max-width: 450px;
        margin: auto;
        padding: 20px;
        border-radius: 15px;
        background: #fff;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        text-align: center;
    }

    #reader {
        width: 100%;
        border-radius: 10px;
        overflow: hidden;
    }

    .result-box {
        margin-top: 15px;
        padding: 12px;
        border-radius: 10px;
        display: none;
    }

    .success {
        background: #d1f7d6;
        color: #1a7f37;
    }

    .error {
        background: #ffd6d6;
        color: #a10000;
    }

    .pulse {
        animation: pulse 0.6s ease;
    }

    @@keyframes pulse {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.05);
        }

        100% {
            transform: scale(1);
        }
    }
</style>

<div class="container mt-4">

    <div class="scanner-box">

        <h4><i class="fas fa-qrcode"></i> Live QR Scanner</h4>

        <div id="reader"></div>

        <div id="resultBox" class="result-box"></div>

        <input type="hidden" id="taskId" value="@((ViewBag.TaskId ?? 0).ToString())" />

    </div>

</div>

<!-- BEEP SOUND -->
<audio id="beepSound" src="https://actions.google.com/sounds/v1/alarms/beep_short.ogg"></audio>

<script src="https://unpkg.com/html5-qrcode"></script>

<script>

    let isScanning = false;
    let scanner;

    function showResult(message, isSuccess) {
        const box = document.getElementById("resultBox");

        box.style.display = "block";
        box.className = "result-box " + (isSuccess ? "success" : "error");
        box.innerHTML = message;

        box.classList.add("pulse");

        setTimeout(() => box.classList.remove("pulse"), 600);
    }

    function playBeep() {
        document.getElementById("beepSound").play();
    }

    function stopScanner() {
        if (scanner) {
            scanner.clear().catch(() => {});
        }
    }

    function onScanSuccess(decodedText) {

        if (isScanning) return;
        isScanning = true;

        fetch('@Url.Action("Verify", "QrScan")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: `qrText=${encodeURIComponent(decodedText)}&taskId=${document.getElementById("taskId").value}`
        })
        .then(res => res.json())
        .then(data => {

            if (data.success) {
                playBeep();

                showResult(
                    `✔ Success<br>Student: ${data.name}<br>ID: ${data.student}`,
                    true
                );

                // OPTIONAL: stop scanner after success
                // stopScanner();
            }
            else {
                showResult("✖ " + data.message, false);
            }

            setTimeout(() => {
                isScanning = false;
            }, 2000);

        })
        .catch(() => {
            showResult("Server error", false);
            isScanning = false;
        });
    }

    onScanFailure(error) {
    console.warn(error);
    }
    scanner = new Html5QrcodeScanner(
        "reader",
        {
            fps: 10,
            qrbox: 250,
            rememberLastUsedCamera: true
        }
    );

    scanner.render(onScanSuccess);

</script>