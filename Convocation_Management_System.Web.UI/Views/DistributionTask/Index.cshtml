@model IEnumerable<Convocation.Entities.DistributionTask>

@{
    ViewData["Title"] = "Distribution Tasks";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between mb-3">
        <h2>Distribution Tasks</h2>

        <a asp-action="Create" class="btn btn-primary">
            + Create Task
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <table class="table table-bordered">

        <thead>
            <tr>
                <th>Title</th>
                <th>Event</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.TaskTitle</td>

                    <td>
                        @item.Event?.EventTitle
                    </td>

                    <td>
                        @if (item.Status == "Completed")
                        {
                            <span class="badge bg-success">Completed</span>
                        }
                        else if (item.Status == "In Progress")
                        {
                            <span class="badge bg-warning text-dark">In Progress</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pending</span>
                        }
                    </td>

                    <td class="d-flex gap-1">

                        <a asp-action="Edit"
                           asp-route-id="@item.DistributionTaskId"
                           class="btn btn-sm btn-warning">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.DistributionTaskId"
                           class="btn btn-sm btn-danger">
                            Delete
                        </a>

                        <a asp-controller="DistributionScan"
                           asp-action="Scan"
                           asp-route-taskId="@item.DistributionTaskId"
                           class="btn btn-dark btn-sm">
                            Scan QR
                        </a>

                    </td>
                </tr>
            }
        </tbody>

    </table>
</div>