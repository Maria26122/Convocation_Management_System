@model IEnumerable<Convocation.Entities.DistributionTask>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "My Tasks";

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}

<div class="container mt-4">

    <h2 class="mb-3">My Assigned Tasks</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No tasks assigned yet.
        </div>
    }
    else
    {
        <table class="table table-bordered table-striped">

            <thead class="table-dark">
                <tr>
                    <th>Task Title</th>
                    <th>Event</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                    @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TaskTitle</td>

                        <td>@item.Event?.EventTitle</td>

                        <td>
                            <span class="badge bg-@(item.Status == "Completed" ? "success" : "warning")">
                                @item.Status
                            </span>
                        </td>

                        <td>@item.CreatedAt.ToString("dd MMM yyyy hh:mm tt")</td>

                        <td>
                            <a asp-controller="QrScan"
                               asp-action="Scan"
                               asp-route-taskId="@item.DistributionTaskId"
                               class="btn btn-sm btn-primary">
                                QR Scanner
                            </a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    }
</div>