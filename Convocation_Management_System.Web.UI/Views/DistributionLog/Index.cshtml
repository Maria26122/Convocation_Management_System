@model IEnumerable<Convocation.Entities.DistributionLog>

@{
    ViewData["Title"] = "Distribution Logs";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Distribution Logs</h2>

        <a asp-action="Create"
               class="btn btn-primary">
            New Distribution
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <table class="table table-bordered table-striped table-hover">

        <thead class="table-dark">
            <tr>
                <th>Participant</th>
                <th>Event</th>
                <th>Distribution Type</th>
                <th>Status</th>
                <th>Date</th>
                <th>Remarks</th>
                <th width="180">Action</th>
            </tr>
        </thead>

        <tbody>

            @if (Model?.Any() == true)
            {
                @foreach (var item in Model!)           {
                    <tr>

                        <td>
                            @item.Participant?.UserAccount?.FullName
                        </td>

                        <td>
                            @item.Event?.EventTitle
                        </td>

                        <td>
                            @item.ActionType
                        </td>

                        <td>
                            @if (item.ActionType != null)
                            {
                                <span class="badge bg-success">
                                    Delivered
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Pending
                                </span>
                            }
                        </td>

                        <td>
                            @(item.ActionDate.ToString("dd MMM yyyy hh:mm tt"))
                        </td>

                        <td>
                            @item.Remarks
                        </td>

                        <td>

                            <a asp-action="Details"
                                   asp-route-id="@item.DistributionLogId"
                                   class="btn btn-info btn-sm">
                                Details
                            </a>

                            <a asp-action="Delete"
                                   asp-route-id="@item.DistributionLogId"
                                   class="btn btn-danger btn-sm">
                                Delete
                            </a>

                        </td>

                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">
                        No distribution records found.
                    </td>
                </tr>
            }

        </tbody>

    </table>

    </div>