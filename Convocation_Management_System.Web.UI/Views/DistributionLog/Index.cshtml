@model IEnumerable<Convocation.Entities.DistributionLog>

@{
    ViewData["Title"] = "Distribution Logs";
}

<div class="container mt-4">

    <h3 class="mb-3">Distribution Logs</h3>

    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Student</th>
                <th>Registration</th>
                <th>Type</th>
                <th>Status</th>
                <th>Food Menu</th>
                <th>Distributed At</th>
                <th>Verified By</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @(item.Registration?.Participant?.UserAccount?.FullName
                            ?? item.Registration?.Participant?.StudentId
                            ?? "Unknown")
                    </td>

                    <td>@item.RegistrationId</td>

                    <td>@item.ActionType</td>

                    <td>
                        <span class="badge bg-success">
                            @item.DistributionStatus
                        </span>
                    </td>

                    <td>@(item.FoodMenu?.MenuName ?? "-")</td>

                    <td>@item.ActionDate.ToString("dd MMM yyyy hh:mm tt")</td>

                    <td>@(item.UserAccount?.FullName ?? "System")</td>
                </tr>
            }
        </tbody>
    </table>
</div>