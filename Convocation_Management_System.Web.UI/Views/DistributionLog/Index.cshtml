@model IEnumerable<Convocation.Entities.DistributionLog>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Distribution Log";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Distribution Log</h2>
    <a asp-action="Create" class="btn btn-primary">Add Distribution</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Participant</th>
            <th>Student ID</th>
            <th>Item Name</th>
            <th>Distributed At</th>
            <th>Distributed By</th>
            <th>Remarks</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Participant?.UserAccount?.FullName</td>
                <td>@item.Participant?.StudentId</td>
                <td>@item.ItemName</td>
                <td>@item.DistributedAt.ToString("dd MMM yyyy hh:mm tt")</td>
                <td>@item.DistributedBy</td>
                <td>@item.Remarks</td>
            </tr>
        }
    </tbody>
</table>