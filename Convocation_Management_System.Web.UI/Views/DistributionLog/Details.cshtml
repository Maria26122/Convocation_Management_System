@model Convocation.Entities.DistributionLog

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Distribution Log Details";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white">
        <h4 class="mb-0">Distribution Log Details</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Distribution Log ID</dt>
            <dd class="col-sm-9">@Model.DistributionLogId</dd>

            <dt class="col-sm-3">Registration ID</dt>
            <dd class="col-sm-9">@Model.RegistrationId</dd>

            <dt class="col-sm-3">Participant</dt>
            <dd class="col-sm-9">@Model.Registration?.Participant?.UserAccount?.FullName</dd>

            <dt class="col-sm-3">Event</dt>
            <dd class="col-sm-9">@Model.Registration?.Event?.EventTitle</dd>

            <dt class="col-sm-3">Action Type</dt>
            <dd class="col-sm-9">@Model.ActionType</dd>

            <dt class="col-sm-3">Action Date</dt>
            <dd class="col-sm-9">@Model.ActionDate.ToString("dd MMM yyyy hh:mm tt")</dd>

            <dt class="col-sm-3">Handled By</dt>
            <dd class="col-sm-9">@Model.UserAccount?.FullName</dd>

            <dt class="col-sm-3">Note</dt>
            <dd class="col-sm-9">@Model.Note</dd>

            <dt class="col-sm-3">Remarks</dt>
            <dd class="col-sm-9">@Model.Remarks</dd>
        </dl>

        <a asp-action="Edit" asp-route-id="@Model.DistributionLogId" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
    </div>
</div>