@model Convocation.Entities.DistributionLog

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Distribution Log Details";
}

<div class="details-card">
    <h3 class="details-title mb-4">Distribution Log Details</h3>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="label-title">Log ID</div>
            <div class="value-text">@Model.DistributionLogId</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Participant Id</div>
            <div class="value-text">@Model.ParticipantId</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Participant</div>
            <div class="value-text">@Model.Participant?.StudentId</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Item Name</div>
            <div class="value-text">@Model.ItemName</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Distributed At</div>
            <div class="value-text">@Model.DistributedAt.ToString("dd MMM yyyy hh:mm tt")</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Distributed By</div>
            <div class="value-text">@Model.DistributedBy</div>
        </div>
        <div class="col-md-12">
            <div class="label-title">Remarks</div>
            <div class="value-text">@Model.Remarks</div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="Edit" asp-route-id="@Model.DistributionLogId" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>