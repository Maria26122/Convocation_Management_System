@model Convocation.Entities.DistributionLog

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Distribution Log Details";
}

<div class="details-card">
    <h3 class="details-title mb-4">Distribution Log Details</h3>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="label-title">Log ID</div>
            <div class="value-text">@Model.DistributionLogId</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Registration ID</div>
            <div class="value-text">#@Model.RegistrationId</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Participant</div>
            <div class="value-text">@Model.Registration?.Participant?.StudentId</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Event</div>
            <div class="value-text">@Model.Registration?.Event?.EventTitle</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Staff/User</div>
            <div class="value-text">@Model.UserAccount?.FullName</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Action Type</div>
            <div class="value-text"><span class="badge-status badge-info">@Model.ActionType</span></div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Action Date</div>
            <div class="value-text">@Model.ActionDate.ToString("dd MMM yyyy hh:mm tt")</div>
        </div>
        <div class="col-md-12">
            <div class="label-title">Note</div>
            <div class="value-text">@Model.Note</div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="Edit" asp-route-id="@Model.DistributionLogId" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>