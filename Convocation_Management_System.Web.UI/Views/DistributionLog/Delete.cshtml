@model Convocation.Entities.DistributionLog

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Delete Distribution Log";
}

<div class="delete-card">
    <h3 class="delete-title mb-2 text-danger">Delete Distribution Log</h3>
    <p class="text-soft">Are you sure you want to delete this distribution log?</p>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="label-title">Registration ID</div>
            <div class="value-text">#@Model.RegistrationId</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Action Type</div>
            <div class="value-text">@Model.ActionType</div>
        </div>
        <div class="col-md-6">
            <div class="label-title">Action Date</div>
            <div class="value-text">@Model.ActionDate.ToString("dd MMM yyyy hh:mm tt")</div>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-4">
        <input type="hidden" asp-for="DistributionLogId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>