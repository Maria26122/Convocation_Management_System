@model Convocation.Entities.DistributionLog

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Delete Distribution Log";
}

<div class="card shadow-sm border-0">

    <div class="card-header bg-white">
        <h4 class="mb-0 text-danger">Delete Distribution Log</h4>
    </div>

    <div class="card-body">

        <h5 class="mb-3">
            Are you sure you want to delete this distribution log?
        </h5>

        <dl class="row">

            <dt class="col-sm-3">Participant</dt>
            <dd class="col-sm-9">
                @Model.Participant?.UserAccount?.FullName
            </dd>

            <dt class="col-sm-3">Event</dt>
            <dd class="col-sm-9">
                @Model.Event?.EventTitle
            </dd>

            <dt class="col-sm-3">Action Type</dt>
            <dd class="col-sm-9">
                @Model.ActionType
            </dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @(Model.ActionType != null ? "Delivered" : "Pending")
            </dd>

            <dt class="col-sm-3">Action Date</dt>
            <dd class="col-sm-9">
                @(Model.ActionDate.ToString("dd MMM yyyy hh:mm tt"))
            </dd>

            <dt class="col-sm-3">Remarks</dt>
            <dd class="col-sm-9">
                @Model.Remarks
            </dd>

        </dl>

        <form asp-action="Delete" method="post">

            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="DistributionLogId" />

            <button type="submit" class="btn btn-danger">
                Delete
            </button>

            <a asp-action="Index" class="btn btn-secondary ms-2">
                Back
            </a>

        </form>

    </div>
</div>