@model Convocation.Entities.DistributionLog

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Delete Distribution Log";
}

<h2 class="mb-4">Delete Distribution Log</h2>

<div class="alert alert-warning">
    Are you sure you want to delete this distribution record?
</div>

<table class="table table-bordered">
    <tr>
        <th>Log Id</th>
        <td>@Model.DistributionLogId</td>
    </tr>
    <tr>
        <th>Participant Id</th>
        <td>@Model.ParticipantId</td>
    </tr>
    <tr>
        <th>Student Id</th>
        <td>@Model.Participant?.StudentId</td>
    </tr>
    <tr>
        <th>Item Name</th>
        <td>@Model.ItemName</td>
    </tr>
    <tr>
        <th>Distributed At</th>
        <td>@Model.DistributedAt.ToString("dd MMM yyyy hh:mm tt")</td>
    </tr>
    <tr>
        <th>Distributed By</th>
        <td>@Model.DistributedBy</td>
    </tr>
    <tr>
        <th>Remarks</th>
        <td>@Model.Remarks</td>
    </tr>
</table>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="DistributionLogId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>