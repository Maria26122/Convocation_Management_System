@model Convocation.Entities.DistributionLog

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Distribution Log";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white">
        <h4 class="mb-0">Edit Distribution Log</h4>
    </div>
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.DistributionLogId" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="DistributionLogId" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="RegistrationId" class="form-label"></label>
                <select asp-for="RegistrationId" class="form-select" asp-items="ViewBag.RegistrationId">
                    <option value="">-- Select Registration --</option>
                </select>
                <span asp-validation-for="RegistrationId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ActionType" class="form-label"></label>
                <input asp-for="ActionType" class="form-control" />
                <span asp-validation-for="ActionType" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Note" class="form-label"></label>
                <input asp-for="Note" class="form-control" />
                <span asp-validation-for="Note" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Remarks" class="form-label"></label>
                <input asp-for="Remarks" class="form-control" />
                <span asp-validation-for="Remarks" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Update</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}