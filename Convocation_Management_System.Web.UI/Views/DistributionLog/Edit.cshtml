@model Convocation.Entities.DistributionLog

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Distribution Log";
}

<div class="form-card">
    <h3 class="form-title mb-4">Edit Distribution Log</h3>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="DistributionLogId" />
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="ParticipantId" class="form-label"></label>
                <select asp-for="ParticipantId" class="form-select" asp-items="ViewBag.ParticipantId">
                    <option value="">-- Select Participant --</option>
                </select>
                <span asp-validation-for="ParticipantId" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="ItemName" class="form-label"></label>
                <input asp-for="ItemName" class="form-control" />
                <span asp-validation-for="ItemName" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="DistributedAt" class="form-label"></label>
                <input asp-for="DistributedAt" type="datetime-local" class="form-control" />
                <span asp-validation-for="DistributedAt" class="text-danger"></span>
            </div>

            <div class="col-md-12">
                <label asp-for="Remarks" class="form-label"></label>
                <textarea asp-for="Remarks" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Remarks" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Update</button>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </form>
</div>