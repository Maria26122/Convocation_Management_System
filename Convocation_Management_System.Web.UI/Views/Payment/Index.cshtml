@model IEnumerable<Convocation.Entities.Payment>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Payments";
}

<div class="page-card">
    <div class="page-header">
        <h3>Payment List</h3>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i> Add New Payment
        </a>
    </div>

    <div class="table-responsive">
        <table class="table align-middle table-hover">
            <thead>
                <tr>
                    <th>Registration</th>
                    <th>Participant</th>
                    <th>Event</th>
                    <th>Method</th>
                    <th>Transaction ID</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Payment Date</th>
                    <th style="width: 220px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>#@item.RegistrationId</td>
                            <td>@item.Registration?.Participant?.StudentId</td>
                            <td>@item.Registration?.Event?.EventTitle</td>
                            <td>@item.PaymentMethod</td>
                            <td>@item.TransactionId</td>
                            <td>@item.PaidAmount</td>
                            <td>
                                @if (item.PaymentStatus == "Paid")
                                {
                                    <span class="badge-status badge-success">Paid</span>
                                }
                                else if (item.PaymentStatus == "Pending")
                                {
                                    <span class="badge-status badge-warning">Pending</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-danger">Failed</span>
                                }
                            </td>
                            <td>
                                @(item.PaymentDate.HasValue? item.PaymentDate.Value.ToString("dd MMM yyyy hh:mm tt") : "N/A")
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.PaymentId" class="btn btn-sm btn-info">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.PaymentId" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.PaymentId" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center text-soft">No payments found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>