@model Convocation.Entities.Payment

@{
    ViewData["Title"] = "Payment Checkout";
    Layout = "~/Views/Shared/_ParticipantLayout.cshtml";
}

<div class="page-card">
    <h4 class="section-title">Payment Checkout</h4>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h5>@Model.Registration?.Event?.EventTitle</h5>

            <p>
                <strong>Registration ID:</strong> @Model.RegistrationId
            </p>

            <p>
                <strong>Amount:</strong> @Model.PaidAmount.ToString("0.00") BDT
            </p>

            <p>
                <strong>Status:</strong>
                @if (Model.PaymentStatus == "Paid")
                {
                    <span class="badge bg-success">Paid</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Pending</span>
                }
            </p>

            @if (Model.PaymentStatus != "Paid")
            {
                <form asp-action="MarkPaid" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="registrationId" value="@Model.RegistrationId" />

                    <button type="submit" class="btn btn-success">
                        Pay Now
                    </button>
                </form>
            }
            else
            {
                <a asp-controller="Participant" asp-action="MyQrPass" class="btn btn-primary">
                    View QR Pass
                </a>
            }
        </div>
    </div>
</div>