@using Microsoft.AspNetCore.Http

@{
    var role = Context.Session.GetString("Role") ?? "";
    var fullName = Context.Session.GetString("FullName") ?? "";

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
   
    bool isDashboard = currentController == "Participant" && currentAction == "Dashboard";
    bool isProfile = currentController == "Participant" && currentAction == "MyProfile";
    bool isRegistration = currentController == "Participant" && currentAction == "MyRegistration";
    bool isPayment = currentController == "Participant" && currentAction == "MyPayment";
    bool isQr = currentController == "Participant" && currentAction == "MyQrPass";
   
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Participant Panel</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
            :root {
                --sidebar-bg: #ffffff;
                --sidebar-border: #e5e7eb;
                --text: #374151;
                --primary: #4f46e5;
                --primary-soft: #eef2ff;
                --danger: #dc2626;
                --bg: #f8fafc;
                --shadow: 0 10px 30px rgba(15,23,42,0.06);
            }

            body {
                margin: 0;
                font-family: 'Segoe UI', sans-serif;
                background: var(--bg);
            }

            .app {
                display: flex;
                min-height: 100vh;
            }

            /* SIDEBAR */
            .sidebar {
                width: 270px;
                background: var(--sidebar-bg);
                border-right: 1px solid var(--sidebar-border);
                padding: 20px;
                position: fixed;
                height: 100vh;
            }

            .brand {
                display: flex;
                gap: 12px;
                align-items: center;
                margin-bottom: 25px;
            }

                .brand i {
                    font-size: 22px;
                    color: var(--primary);
                }

                .brand h4 {
                    margin: 0;
                    font-weight: 800;
                }

            .menu {
                display: flex;
                flex-direction: column;
                gap: 10px;
            }

                .menu a {
                    text-decoration: none;
                    color: var(--text);
                    padding: 12px 14px;
                    border-radius: 12px;
                    display: flex;
                    gap: 10px;
                    align-items: center;
                    transition: 0.2s;
                }

                    .menu a:hover {
                        background: #f3f4f6;
                        color: var(--primary);
                    }

            .active {
                background: var(--primary-soft);
                color: var(--primary) !important;
                font-weight: 600;
            }

            .logout {
                color: var(--danger);
            }

            /* CONTENT */
            .content {
                margin-left: 270px;
                width: calc(100% - 270px);
                padding: 25px;
            }

            .topbar {
                background: white;
                padding: 18px;
                border-radius: 16px;
                box-shadow: var(--shadow);
                margin-bottom: 20px;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .user {
                font-weight: 600;
                color: var(--primary);
            }

            @@media(max-width: 768px) {
                .sidebar {
                    position: relative;
                    width: 100%;
                    height: auto;
                }

                .content {
                    margin-left: 0;
                    width: 100%;
                }

                .app {
                    flex-direction: column;
                }
            }
    </style>
</head>

<body>

    <div class="app">

        <!-- SIDEBAR -->
        <aside class="sidebar">

            <div class="brand">
                <i class="fas fa-graduation-cap"></i>
                <h4>Convocation</h4>
            </div>

            <div class="menu">

                <a asp-controller="Participant" asp-action="Dashboard"
                   class="@(isDashboard ? "active" : "")">
                    <i class="fas fa-home"></i> Dashboard
                </a>

                <a asp-controller="Participant" asp-action="MyProfile"
                   class="@(isProfile ? "active" : "")">
                    <i class="fas fa-user"></i> Profile
                </a>

                <a asp-controller="Participant" asp-action="MyRegistration"
                   class="@(isRegistration ? "active" : "")">
                    <i class="fas fa-file"></i> Registration
                </a>

                <a asp-controller="Participant" asp-action="MyPayment"
                   class="@(isPayment ? "active" : "")">
                    <i class="fas fa-credit-card"></i> Payment
                </a>

                <a asp-controller="Participant" asp-action="MyQrPass"
                   class="@(isQr ? "active" : "")">
                    <i class="fas fa-qrcode"></i> QR Pass
                </a>

                <a asp-controller="Account" asp-action="Logout"
                   class="logout">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>

            </div>

        </aside>

        <!-- CONTENT -->
        <main class="content">

            <div class="topbar">
                <div>
                    <h3>@ViewData["Title"]</h3>
                </div>

                <div class="user">
                    @fullName
                </div>
            </div>

            @RenderBody()

        </main>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>