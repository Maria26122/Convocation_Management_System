@model Convocation_Management_System.Web.UI.Models.StaffTaskViewModel

@{
    ViewData["Title"] = "Assign Staff";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<form asp-action="Create" method="post">

    <label>Distribution Task</label>
    <select asp-for="DistributionTaskId"
            asp-items="Model.DistributionTasks"
            class="form-control">
        <option value="">-- Select Task --</option>
    </select>

    <label>Staff</label>
    <select asp-for="UserAccountId"
            asp-items="Model.staffs"
            class="form-control">
        <option value="">-- Select Staff --</option>
    </select>

    <label>Status</label>
    <select asp-for="Status" class="form-control">
        <option value="Pending">Pending</option>
        <option value="InProgress">In Progress</option>
        <option value="Completed">Completed</option>
    </select>

    <button class="btn btn-success mt-2">Save</button>
</form>