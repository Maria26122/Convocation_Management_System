@model Convocation.Entities.StaffTask

@{
    ViewData["Title"] = "Delete Staff Task";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-card">
    <h4 class="section-title text-danger">Delete Staff Task</h4>

    <div class="alert alert-warning">
        Are you sure you want to delete this task?
    </div>

    <dl class="row">
        <dt class="col-sm-3">Event</dt>
        <dd class="col-sm-9">@Model.Event?.EventTitle</dd>

        <dt class="col-sm-3">Staff</dt>
        <dd class="col-sm-9">@Model.StaffUserAccount?.FullName</dd>

        <dt class="col-sm-3">Task</dt>
        <dd class="col-sm-9">@Model.TaskName</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.Status</dd>
    </dl>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="StaffTaskId" />

        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>