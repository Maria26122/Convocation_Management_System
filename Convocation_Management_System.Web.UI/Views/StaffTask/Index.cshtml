@model IEnumerable<Convocation.Entities.StaffTask>

@{
    ViewData["Title"] = "Staff Tasks";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<a asp-action="Create" class="btn btn-primary mb-2">Assign Task</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>TaskTitle</th>
            <th>Staff</th>
            <th>Status</th>
            <th>Assigned At</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.DistributionTask?.TaskTitle</td>
                <td>@item.UserAccount?.FullName</td>
                <td>@item.Status</td>
                <td>@item.AssignedAt.ToString("dd MMM yyyy")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.StaffTaskId" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.StaffTaskId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>