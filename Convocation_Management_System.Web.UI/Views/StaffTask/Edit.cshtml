@model Convocation_Management_System.Web.UI.Models.StaffTaskViewModel
@{
    ViewData["Title"] = "Edit Task";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white">
        <h4 class="mb-0">Edit Staff Task</h4>
    </div>

    <div class="card-body">

        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="StaffTaskId" />

            <!-- STAFF -->
            <div class="mb-3">
                <label class="form-label">Assign To</label>
                <select asp-for="UserAccountId"
                        class="form-control"
                        asp-items="ViewBag.Users">
                </select>
            </div>

            <!-- TITLE -->
            <div class="mb-3">
                <label class="form-label">Task Title</label>
                <input asp-for="TaskTitle" class="form-control" />
                <span asp-validation-for="TaskTitle" class="text-danger"></span>
            </div>

            <!-- DESCRIPTION -->
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>

            <!-- STATUS -->
            <div class="mb-3">
                <label class="form-label">Status</label>
                <select asp-for="Status" class="form-control">

                    <option value="Pending">Pending</option>
                    <option value="InProgress">In Progress</option>
                    <option value="Completed">Completed</option>

                </select>
            </div>

            <!-- REMARKS -->
            <div class="mb-3">
                <label class="form-label">Remarks</label>
                <input asp-for="Remarks" class="form-control" />
            </div>

            <!-- BUTTONS -->
            <button type="submit" class="btn btn-primary">
                Update
            </button>

            <a asp-action="Index" class="btn btn-secondary ms-2">
                Back
            </a>

        </form>

    </div>
</div>