@model Convocation.Entities.StaffTask

@{
    ViewData["Title"] = "Task Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white">
        <h4 class="mb-0">Staff Task Details</h4>
    </div>

    <div class="card-body">

        <dl class="row">

            <dt class="col-sm-3">Task Title</dt>
            <dd class="col-sm-9">@Model.TaskTitle</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrEmpty(Model.Description) ? "N/A" : Model.Description)
            </dd>

            <dt class="col-sm-3">Assigned To</dt>
            <dd class="col-sm-9">
                @(Model.UserAccount?.FullName ?? "N/A")
            </dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">

                @if (Model.Status == "Completed")
                {
                    <span class="badge bg-success">Completed</span>
                }
                else if (Model.Status == "InProgress")
                {
                    <span class="badge bg-warning text-dark">In Progress</span>
                }
                else
                {
                    <span class="badge bg-secondary">Pending</span>
                }

            </dd>

            <dt class="col-sm-3">Assigned At</dt>
            <dd class="col-sm-9">
                @Model.AssignedAt.ToString("dd MMM yyyy hh:mm tt")
            </dd>

            <dt class="col-sm-3">Completed At</dt>
            <dd class="col-sm-9">
                @(Model.CompletedAt.HasValue
                    ? Model.CompletedAt.Value.ToString("dd MMM yyyy hh:mm tt")
                    : "Not completed yet")
            </dd>

            <dt class="col-sm-3">Remarks</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrEmpty(Model.Remarks) ? "N/A" : Model.Remarks)
            </dd>

        </dl>

        <div class="mt-3">
            <a asp-action="Edit"
                   asp-route-id="@Model.StaffTaskId"
                   class="btn btn-primary">
                Edit
            </a>

            <a asp-action="Index"
                   class="btn btn-secondary ms-2">
                Back
            </a>
        </div>

    </div>
</div>