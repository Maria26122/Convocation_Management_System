@model Convocation.Entities.StaffTask

@{
    ViewData["Title"] = "Staff Task Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-card">
    <h4 class="section-title">Staff Task Details</h4>

    <dl class="row">
        <dt class="col-sm-3">Event</dt>
        <dd class="col-sm-9">@Model.Event?.EventTitle</dd>

        <dt class="col-sm-3">Staff</dt>
        <dd class="col-sm-9">@Model.StaffUserAccount?.FullName</dd>

        <dt class="col-sm-3">Task</dt>
        <dd class="col-sm-9">@Model.TaskName</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@Model.Description</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.Status</dd>

        <dt class="col-sm-3">Assigned At</dt>
        <dd class="col-sm-9">@Model.AssignedAt.ToString("dd MMM yyyy hh:mm tt")</dd>

        <dt class="col-sm-3">Completed At</dt>
        <dd class="col-sm-9">@(Model.CompletedAt.HasValue? Model.CompletedAt.Value.ToString("dd MMM yyyy hh:mm tt") : "-")</dd>
    </dl>

    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>